---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/who-we-are', label: 'Who We Are' },
  {
    label: 'Our Advocacy',
    children: [
      { href: '/our-advocacy', label: 'Projects' },
      { href: '/world-tb-day', label: 'World TB Day' },
      { href: '/opinion-pieces', label: 'Opinion Pieces' },
      { href: '/advocacy-letters', label: 'Advocacy Letters' },
    ]
  },
  {
    label: 'Our Stories',
    children: [
      { href: '/tb-champion-stories', label: 'TB Champion Stories' },
      { href: '/media-articles', label: 'Media Articles' },
    ]
  },
  {
    label: 'Using Science',
    children: [
      { href: '/research-publications', label: 'Research Publications' },
      { href: '/tb-questions-answers', label: 'TB Questions & Answers' },
      { href: '/resources', label: 'Resources' },
    ]
  },
  {
    label: 'Support Our Work',
    children: [
      { href: '/donations', label: 'Donate' },
      { href: '/volunteer', label: 'Volunteer' },
    ]
  },
  { href: '/events', label: 'Events' },
  { href: '/news', label: 'TB News' },
  { href: '/contact', label: 'Contact Us' },
];
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-[#1a1a2e]">
  <nav class="w-full px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group shrink-0">
        <img src="/logo.png" alt="TB Free Foundation of Namibia" class="h-16 w-auto" />
      </a>

      <!-- Centered Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-1 absolute left-1/2 -translate-x-1/2 z-[60]">
        <a href="/who-we-are" class:list={['px-4 py-2 text-sm font-medium rounded-lg transition-all duration-200', currentPath === '/who-we-are' ? 'text-white bg-white/10' : 'text-white/80 hover:text-white hover:bg-white/10']}>
          Who We Are
        </a>
        <!-- Our Advocacy dropdown -->
        <div class="relative group/drop">
          <button class="flex items-center gap-1 px-4 py-2 text-sm font-medium text-white/80 hover:text-white hover:bg-white/10 rounded-lg transition-all duration-200">
            Our Advocacy
            <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover/drop:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="absolute top-full left-0 mt-1 w-52 bg-[#1a1a2e] border border-white/10 rounded-xl shadow-2xl opacity-0 invisible group-hover/drop:opacity-100 group-hover/drop:visible transition-all duration-200 z-[200] py-2">
            <a href="/our-advocacy" class="block px-4 py-2.5 text-sm text-white/70 hover:text-white hover:bg-white/5 transition-colors">Projects</a>
            <a href="/world-tb-day" class="block px-4 py-2.5 text-sm text-white/70 hover:text-white hover:bg-white/5 transition-colors">World TB Day</a>
            <a href="/opinion-pieces" class="block px-4 py-2.5 text-sm text-white/70 hover:text-white hover:bg-white/5 transition-colors">Opinion Pieces</a>
            <a href="/advocacy-letters" class="block px-4 py-2.5 text-sm text-white/70 hover:text-white hover:bg-white/5 transition-colors">Advocacy Letters</a>
          </div>
        </div>
        <!-- Support Our Work dropdown -->
        <div class="relative group/drop2">
          <button class="flex items-center gap-1 px-4 py-2 text-sm font-medium text-white/80 hover:text-white hover:bg-white/10 rounded-lg transition-all duration-200">
            Support Our Work
            <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover/drop2:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="absolute top-full left-0 mt-1 w-44 bg-[#1a1a2e] border border-white/10 rounded-xl shadow-2xl opacity-0 invisible group-hover/drop2:opacity-100 group-hover/drop2:visible transition-all duration-200 z-[200] py-2">
            <a href="/donations" class="block px-4 py-2.5 text-sm text-white/70 hover:text-white hover:bg-white/5 transition-colors">Donate</a>
            <a href="/volunteer" class="block px-4 py-2.5 text-sm text-white/70 hover:text-white hover:bg-white/5 transition-colors">Volunteer</a>
          </div>
        </div>
        <a href="/contact" class:list={['px-4 py-2 text-sm font-medium rounded-lg transition-all duration-200', currentPath === '/contact' ? 'text-white bg-white/10' : 'text-white/80 hover:text-white hover:bg-white/10']}>
          Contact Us
        </a>
      </nav>

      <!-- Burger + Namibian heart flag -->
      <div class="flex items-center gap-2">
        <!-- Burger Menu Button (all screen sizes) -->
        <button
          id="burger-btn"
          class="relative w-10 h-10 flex flex-col items-center justify-center gap-1.5 rounded-lg text-white hover:bg-white/10 transition-colors z-60"
          aria-label="Toggle navigation menu"
          aria-expanded="false"
        >
          <span id="burger-line-1" class="block w-6 h-0.5 bg-white rounded-full transition-all duration-300 origin-center"></span>
          <span id="burger-line-2" class="block w-6 h-0.5 bg-white rounded-full transition-all duration-300"></span>
          <span id="burger-line-3" class="block w-6 h-0.5 bg-white rounded-full transition-all duration-300 origin-center"></span>
        </button>

        <!-- Namibian heart flag icon -->
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 44 40" width="40" height="36" aria-label="Namibia" role="img">
          <defs>
            <clipPath id="hdr-heart">
              <path d="M22,39 C22,39 3,26 3,13 C3,7 7.5,3 12,3 C15.5,3 19,5 22,8.5 C25,5 28.5,3 32,3 C36.5,3 41,7 41,13 C41,26 22,39 22,39Z"/>
            </clipPath>
            <radialGradient id="hdr-gloss" cx="28%" cy="22%" r="52%">
              <stop offset="0%" stop-color="white" stop-opacity="0.6"/>
              <stop offset="100%" stop-color="white" stop-opacity="0"/>
            </radialGradient>
          </defs>
          <g clip-path="url(#hdr-heart)">
            <!-- Blue upper-left triangle -->
            <polygon points="3,3 41,3 3,39" fill="#003580"/>
            <!-- Green lower-right triangle -->
            <polygon points="3,39 41,3 41,39" fill="#009A44"/>
            <!-- White diagonal band (border) -->
            <polygon points="-0.1,35.73 37.9,-0.27 44.1,6.27 6.1,42.27" fill="white"/>
            <!-- Red diagonal band (narrower, on top of white) -->
            <polygon points="0.94,36.82 38.94,0.82 43.06,5.18 5.06,41.18" fill="#C8102E"/>
            <!-- Yellow sun with rays -->
            <circle cx="12" cy="13" r="4.5" fill="#FFCD00"/>
            <g stroke="#FFCD00" stroke-linecap="round">
              <line x1="12" y1="6.5" x2="12" y2="8" stroke-width="1.4"/>
              <line x1="12" y1="18" x2="12" y2="19.5" stroke-width="1.4"/>
              <line x1="5.5" y1="13" x2="7" y2="13" stroke-width="1.4"/>
              <line x1="17" y1="13" x2="18.5" y2="13" stroke-width="1.4"/>
              <line x1="7.4" y1="8.4" x2="8.4" y2="9.4" stroke-width="1.2"/>
              <line x1="15.6" y1="16.6" x2="16.6" y2="17.6" stroke-width="1.2"/>
              <line x1="16.6" y1="8.4" x2="15.6" y2="9.4" stroke-width="1.2"/>
              <line x1="8.4" y1="16.6" x2="7.4" y2="17.6" stroke-width="1.2"/>
            </g>
            <!-- Glossy highlight -->
            <path d="M22,39 C22,39 3,26 3,13 C3,7 7.5,3 12,3 C15.5,3 19,5 22,8.5 C25,5 28.5,3 32,3 C36.5,3 41,7 41,13 C41,26 22,39 22,39Z" fill="url(#hdr-gloss)"/>
          </g>
        </svg>
      </div>
    </div>
  </nav>

  <!-- Full-Screen Overlay Menu -->
  <div id="nav-overlay" class="fixed inset-0 z-50 pointer-events-none opacity-0 transition-opacity duration-300">
    <!-- Backdrop -->
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
    <!-- Menu Panel -->
    <div id="nav-panel" class="absolute top-0 right-0 w-full max-w-sm h-full bg-gradient-to-b from-[#1a1a2e] to-[#111827] shadow-2xl transform translate-x-full transition-transform duration-300 ease-out overflow-y-auto">
      <div class="pt-24 pb-8 px-6">
        <div class="space-y-1">
          {navLinks.map((link) => (
            'children' in link ? (
              <div class="nav-group">
                <button
                  class="nav-group-toggle w-full flex items-center justify-between px-4 py-3 text-[15px] font-medium text-white/80 hover:text-white hover:bg-white/5 rounded-lg transition-all duration-200"
                  aria-expanded="false"
                >
                  {link.label}
                  <svg class="nav-chevron w-4 h-4 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </button>
                <div class="nav-group-children hidden pl-4 space-y-0.5 mt-1">
                  {link.children.map((child) => (
                    <a
                      href={child.href}
                      class:list={[
                        'block px-4 py-2.5 text-sm rounded-lg transition-all duration-200',
                        currentPath === child.href
                          ? 'text-white bg-primary/30 font-medium'
                          : 'text-white/60 hover:text-white hover:bg-white/5'
                      ]}
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            ) : (
              <a
                href={link.href}
                class:list={[
                  'block px-4 py-3 text-[15px] font-medium rounded-lg transition-all duration-200',
                  currentPath === link.href
                    ? 'text-white bg-primary/30'
                    : 'text-white/80 hover:text-white hover:bg-white/5'
                ]}
              >
                {link.label}
              </a>
            )
          ))}
        </div>

        <!-- CTA in menu -->
        <div class="mt-8 pt-6 border-t border-white/10 space-y-3">
          <a href="/donations" class="block w-full px-6 py-3 bg-primary text-white text-center font-semibold rounded-lg hover:bg-primary-dark transition-colors text-sm">
            Donate Now
          </a>
          <a href="/contact" class="block w-full px-6 py-3 bg-white/10 text-white text-center font-medium rounded-lg hover:bg-white/20 transition-colors text-sm border border-white/10">
            Contact Us
          </a>
        </div>

        <!-- Contact Info in menu -->
        <div class="mt-8 pt-6 border-t border-white/10">
          <p class="text-xs text-white/40 uppercase tracking-wider mb-3">Get in Touch</p>
          <a href="mailto:admin@tbfreenamibia.com" class="block text-sm text-white/60 hover:text-white transition-colors mb-1">admin@tbfreenamibia.com</a>
          <p class="text-xs text-white/30 mt-4">"Breaking barriers to END TB"</p>
        </div>
      </div>
    </div>
  </div>
  <!-- Live Fundraising Marquee -->
  <div class="bg-primary/90 overflow-hidden whitespace-nowrap">
    <div class="animate-marquee inline-flex items-center gap-12 py-1.5 text-white text-xs font-semibold tracking-wide">
      <span class="inline-flex items-center gap-2"><span class="w-2 h-2 bg-white rounded-full animate-pulse"></span> LIVE FUNDRAISER: 560forTBFree — Goal: N$80,000 | Raised: N$5,600.00 — <a href="/560fortbfree" class="underline hover:text-amber-300">DONATE NOW</a></span>
      <span class="inline-flex items-center gap-2"><span class="w-2 h-2 bg-white rounded-full animate-pulse"></span> LIVE FUNDRAISER: 560forTBFree — Goal: N$80,000 | Raised: N$5,600.00 — <a href="/560fortbfree" class="underline hover:text-amber-300">DONATE NOW</a></span>
      <span class="inline-flex items-center gap-2"><span class="w-2 h-2 bg-white rounded-full animate-pulse"></span> LIVE FUNDRAISER: 560forTBFree — Goal: N$80,000 | Raised: N$5,600.00 — <a href="/560fortbfree" class="underline hover:text-amber-300">DONATE NOW</a></span>
      <span class="inline-flex items-center gap-2"><span class="w-2 h-2 bg-white rounded-full animate-pulse"></span> LIVE FUNDRAISER: 560forTBFree — Goal: N$80,000 | Raised: N$5,600.00 — <a href="/560fortbfree" class="underline hover:text-amber-300">DONATE NOW</a></span>
    </div>
  </div>
</header>

<style>
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .animate-marquee {
    animation: marquee 20s linear infinite;
  }
</style>

<script>
  const header = document.getElementById('site-header');
  const burgerBtn = document.getElementById('burger-btn');
  const overlay = document.getElementById('nav-overlay');
  const panel = document.getElementById('nav-panel');
  const closeBtn = document.getElementById('nav-close-btn');
  const line1 = document.getElementById('burger-line-1');
  const line2 = document.getElementById('burger-line-2');
  const line3 = document.getElementById('burger-line-3');

  let menuOpen = false;

  function openMenu() {
    menuOpen = true;
    overlay?.classList.remove('opacity-0', 'pointer-events-none');
    overlay?.classList.add('opacity-100', 'pointer-events-auto');
    panel?.classList.remove('translate-x-full');
    panel?.classList.add('translate-x-0');
    burgerBtn?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
    // Animate burger to X
    line1?.classList.add('rotate-45', 'translate-y-[8px]');
    line2?.classList.add('opacity-0');
    line3?.classList.add('-rotate-45', '-translate-y-[8px]');
  }

  function closeMenu() {
    menuOpen = false;
    overlay?.classList.add('opacity-0', 'pointer-events-none');
    overlay?.classList.remove('opacity-100', 'pointer-events-auto');
    panel?.classList.add('translate-x-full');
    panel?.classList.remove('translate-x-0');
    burgerBtn?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    // Animate X back to burger
    line1?.classList.remove('rotate-45', 'translate-y-[8px]');
    line2?.classList.remove('opacity-0');
    line3?.classList.remove('-rotate-45', '-translate-y-[8px]');
  }

  burgerBtn?.addEventListener('click', () => {
    menuOpen ? closeMenu() : openMenu();
  });

  closeBtn?.addEventListener('click', closeMenu);

  // Close on backdrop click
  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay || (!panel?.contains(e.target as Node) && e.target !== burgerBtn)) {
      closeMenu();
    }
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menuOpen) closeMenu();
  });

  // Dropdown toggles
  document.querySelectorAll('.nav-group-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const group = btn.closest('.nav-group');
      const children = group?.querySelector('.nav-group-children');
      const chevron = btn.querySelector('.nav-chevron');
      const isOpen = btn.getAttribute('aria-expanded') === 'true';

      btn.setAttribute('aria-expanded', String(!isOpen));
      children?.classList.toggle('hidden');
      chevron?.classList.toggle('rotate-180');
    });
  });

  // Scroll behavior - always red, deepen shadow on scroll
  window.addEventListener('scroll', () => {
    const scrollY = window.scrollY;
    if (header) {
      if (scrollY > 50) {
        header.style.boxShadow = '0 4px 30px rgba(0, 0, 0, 0.25)';
      } else {
        header.style.boxShadow = 'none';
      }
    }
  });

  // Initialize header style
  if (header) {
    header.style.background = '#1a1a2e';
  }
</script>
