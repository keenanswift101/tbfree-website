---
// HeroSlideshow.astro — Full 9-slide editorial data-journalism slideshow
---

<style>
  .ss-slide {
    display: none;
    opacity: 0;
    transition: opacity 0.8s ease;
  }
  .ss-slide.active {
    display: block;
    opacity: 1;
  }
  .ss-slide.fade-in { opacity: 1; }
  .ss-slide.fade-out { opacity: 0; }

  #ss-bg-img {
    transition: opacity 1s ease;
  }

  .ss-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(255,255,255,0.10);
    border: 1px solid rgba(255,255,255,0.18);
    backdrop-filter: blur(12px);
    cursor: pointer;
    transition: background 0.25s ease, border-color 0.25s ease, transform 0.2s ease;
    color: #fff;
    padding: 0;
  }
  .ss-arrow:hover {
    background: rgba(159,13,13,0.55);
    border-color: rgba(159,13,13,0.7);
    transform: scale(1.08);
  }
  .ss-arrow:active { transform: scale(0.95); }
  .ss-arrow:focus-visible {
    outline: 2px solid #f4a261;
    outline-offset: 2px;
  }

  [data-count] { font-variant-numeric: tabular-nums; }

  @media (max-width: 640px) {
    .ss-slide .grid-cols-3 { grid-template-columns: 1fr 1fr; }
  }
</style>

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">

  <!-- Shared background — dynamic tint + accent system controlled by JS -->
  <div class="absolute inset-0" style="background: linear-gradient(135deg, #0d0c1a 0%, #1a1a2e 60%, #0d0c1a 100%);">
    <img src="/images/image11.png" alt="" id="ss-bg-img"
         class="absolute inset-0 w-full h-full object-cover transition-opacity duration-700"
         style="opacity:0.18;" loading="eager" />
    <!-- Tint overlay: JS sets bg per-slide -->
    <div id="ss-tint" class="absolute inset-0" style="background: rgba(20,16,40,0.72); transition: background 0.7s ease;"></div>
    <!-- Accent blob 1 -->
    <div id="ss-acc1" class="absolute top-1/4 left-1/4 w-72 h-72 rounded-full blur-3xl animate-pulse-slow pointer-events-none" style="background: rgba(159,13,13,0.24); transition: background 1s ease;"></div>
    <!-- Accent blob 2 -->
    <div id="ss-acc2" class="absolute bottom-1/4 right-1/4 w-96 h-96 rounded-full blur-3xl animate-pulse-slow delay-200 pointer-events-none" style="background: rgba(159,13,13,0.12); transition: background 1s ease;"></div>
    <!-- Vignette -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/30 via-transparent to-black/10"></div>
  </div>

  <!-- Slide container -->
  <div id="ss-stage"
       class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-36 pb-24"
       role="region" aria-live="polite">

    <!-- ═══════════════ SLIDE 1 — Hero Title ═══════════════ -->
    <div class="ss-slide active" data-duration="9000" data-bg="/images/image43.jpg">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-[#f4a261] font-semibold text-sm uppercase tracking-wider mb-4 animate-fade-in-up">TB Free Foundation of Namibia</p>
          <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold text-white mb-6 animate-fade-in-up delay-100" style="font-family: var(--font-heading);">
            Breaking Barriers<br>to <span class="text-[#f4a261]">End TB</span>
          </h1>
          <p class="text-lg sm:text-xl text-white/70 max-w-xl leading-relaxed mb-8 animate-fade-in-up delay-200">
            Every year on March 24th, the world unites to raise awareness about tuberculosis. Together, we can end the epidemic.
          </p>
          <div class="inline-flex items-center gap-3 bg-white/10 backdrop-blur-sm rounded-xl px-6 py-3 border border-white/10 mb-8 animate-fade-in-up delay-300">
            <span class="text-white/50 text-sm font-medium uppercase tracking-wider">World TB Day 2026</span>
            <span class="w-1 h-1 bg-white/30 rounded-full"></span>
            <span class="text-white font-semibold text-sm" style="font-family: var(--font-heading);">Yes! We Can End TB.</span>
          </div>
          <div class="flex flex-col sm:flex-row gap-4 animate-fade-in-up delay-400">
            <a href="/who-we-are" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-primary text-white font-semibold rounded-lg hover:bg-primary/90 transition-all duration-200">
              Who We Are
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </a>
            <a href="/our-advocacy" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-white/10 text-white font-semibold rounded-lg border border-white/20 hover:bg-white/20 transition-all duration-200">
              Our Advocacy
            </a>
          </div>
        </div>
        <!-- Right: pulsing image42 -->
        <div class="hidden lg:flex items-center justify-center animate-fade-in-up delay-200">
          <img src="/images/image42.png" alt="YES! We Can End TB" class="animate-img-breathe drop-shadow-2xl" style="max-height: 380px; width: auto;" />
        </div>
      </div>
    </div>

    <!-- ═══════════════ SLIDE 2 — TB Facts ═══════════════ -->
    <div class="ss-slide" data-duration="9000">
      <div class="max-w-5xl mx-auto w-full">

        <!-- Top label bar -->
        <div class="flex items-center gap-4 mb-10 animate-fade-in-up">
          <img src="/logo.png" alt="TB Free Foundation of Namibia" class="h-8 w-auto opacity-80 drop-shadow-md shrink-0" />
          <div class="h-px flex-1 bg-white/15"></div>
          <p class="text-white/40 text-xs uppercase tracking-[0.22em] font-medium shrink-0">World TB Report · Namibia 2025</p>
        </div>

        <!-- Hero editorial block -->
        <div class="grid grid-cols-1 lg:grid-cols-[1fr_160px] gap-6 items-end mb-8 animate-fade-in-up delay-100">
          <div>
            <div class="flex items-center gap-3 mb-4">
              <span class="block w-8 h-0.5 bg-primary"></span>
              <p class="text-primary text-xs font-bold uppercase tracking-[0.2em]">The Burden</p>
            </div>
            <div style="font-family: var(--font-heading);">
              <p class="text-white/45 text-xl sm:text-2xl font-normal leading-tight mb-1">Every year in Namibia,</p>
              <p class="text-white font-bold leading-none mb-2" data-count="13000" style="font-size: clamp(4.5rem, 11vw, 8.5rem); text-shadow: 0 4px 32px rgba(0,0,0,0.5);">13,000</p>
              <p class="text-white/60 text-2xl sm:text-3xl font-medium">people are diagnosed with <span class="text-white">TB</span></p>
            </div>
            <div class="mt-7 max-w-lg">
              <div class="flex items-center justify-between text-xs mb-2">
                <span class="text-white/40 uppercase tracking-wider">Namibia TB incidence vs global average</span>
                <span class="text-primary font-bold text-sm">5× higher</span>
              </div>
              <div class="h-1 bg-white/10 rounded-full overflow-hidden">
                <div class="h-full rounded-full" style="width: 83%; background: linear-gradient(to right, #9f0d0d, rgba(159,13,13,0.3));"></div>
              </div>
              <div class="flex justify-between text-white/25 text-xs mt-1.5">
                <span>Global avg · 133/100k</span>
                <span>Namibia · 422/100k</span>
              </div>
            </div>
          </div>

          <!-- Right: vertical perch stat -->
          <div class="hidden lg:flex flex-col items-center gap-1 pb-1 animate-fade-in-up delay-200">
            <div class="w-px bg-gradient-to-b from-transparent via-white/20 to-white/20" style="height: 80px;"></div>
            <div class="text-center px-4 py-5 rounded-2xl border border-white/15" style="background: rgba(0,30,80,0.35); backdrop-filter: blur(16px);">
              <p class="text-white font-bold leading-none mb-1" style="font-family: var(--font-heading); font-size: 2.4rem; text-shadow: 0 2px 12px rgba(0,0,0,0.5);">422</p>
              <p class="text-[#6ba8d4] text-xs font-bold uppercase tracking-widest leading-tight">per<br/>100k</p>
            </div>
            <div class="w-px bg-gradient-to-b from-white/20 to-transparent" style="height: 40px;"></div>
          </div>
        </div>

        <!-- Bottom 3-pod glass strip -->
        <div class="grid grid-cols-1 sm:grid-cols-3 rounded-2xl overflow-hidden border border-white/12 animate-fade-in-up delay-200" style="background: rgba(0,0,0,0.28); backdrop-filter: blur(20px);">
          <div class="px-5 py-5 border-r border-white/10">
            <div class="w-6 h-0.5 bg-[#009A44] mb-3"></div>
            <p class="text-white font-bold text-xl leading-none mb-1" style="font-family: var(--font-heading);">1,600+<br/>Children</p>
            <p class="text-[#4ade80] text-xs font-bold uppercase tracking-wider mt-2 mb-1">Per year</p>
            <p class="text-white/35 text-xs leading-relaxed">Over 1,600 Namibian children are diagnosed with TB every year — most under age 5</p>
          </div>
          <div class="px-5 py-5 border-r border-white/10">
            <div class="w-6 h-0.5 bg-[#f4a261] mb-3"></div>
            <p class="text-white font-bold text-xl leading-none mb-1" style="font-family: var(--font-heading);">32% TB–HIV<br/>Co-infection</p>
            <p class="text-[#f4a261] text-xs font-bold uppercase tracking-wider mt-2 mb-1">Dual burden</p>
            <p class="text-white/35 text-xs leading-relaxed">1 in 3 TB patients in Namibia also has HIV — both must be treated together</p>
          </div>
          <div class="px-5 py-5 flex flex-col justify-between">
            <div>
              <div class="w-6 h-0.5 bg-primary mb-3"></div>
              <p class="text-white font-bold text-xl leading-none mb-1" style="font-family: var(--font-heading);">TB is<br/>Curable</p>
              <p class="text-primary text-xs font-bold uppercase tracking-wider mt-2 mb-1">85%+ success</p>
              <p class="text-white/35 text-xs leading-relaxed">With free treatment at every Namibian clinic, 85%+ of TB patients fully recover</p>
            </div>
            <a href="/our-advocacy" class="mt-4 inline-flex items-center gap-2 text-primary text-xs font-bold uppercase tracking-widest hover:text-primary/70 transition-colors group">
              Our Advocacy
              <svg class="w-3 h-3 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </a>
          </div>
        </div>

      </div>
    </div>

    <!-- ═══════════════ SLIDE 3 — Know the Signs ═══════════════ -->
    <div class="ss-slide" data-duration="9000">
      <div class="max-w-5xl mx-auto w-full">

        <!-- Top label bar -->
        <div class="flex items-center gap-4 mb-10 animate-fade-in-up">
          <img src="/logo.png" alt="TB Free Foundation of Namibia" class="h-8 w-auto opacity-80 drop-shadow-md shrink-0" />
          <div class="h-px flex-1 bg-white/15"></div>
          <p class="text-white/40 text-xs uppercase tracking-[0.22em] font-medium shrink-0">TB Symptoms · Early Detection Saves Lives</p>
        </div>

        <!-- Hero editorial block -->
        <div class="grid grid-cols-1 lg:grid-cols-[1fr_160px] gap-6 items-end mb-8 animate-fade-in-up delay-100">
          <div>
            <div class="flex items-center gap-3 mb-4">
              <span class="block w-8 h-0.5 bg-[#009A44]"></span>
              <p class="text-[#4ade80] text-xs font-bold uppercase tracking-[0.2em]">Know the Signs</p>
            </div>
            <div style="font-family: var(--font-heading);">
              <p class="text-white/45 text-xl sm:text-2xl font-normal leading-tight mb-1">If you have any of these,</p>
              <p class="text-white font-bold leading-none mb-2" style="font-size: clamp(3.5rem, 9vw, 7rem); text-shadow: 0 4px 32px rgba(0,0,0,0.5);">Get<br/>Tested</p>
              <p class="text-white/60 text-2xl sm:text-3xl font-medium">early diagnosis <span class="text-white">saves lives</span></p>
            </div>
            <div class="mt-7 max-w-lg">
              <div class="flex items-center justify-between text-xs mb-2">
                <span class="text-white/40 uppercase tracking-wider">TB treatment success rate (Namibia)</span>
                <span class="text-[#4ade80] font-bold text-sm">85%+</span>
              </div>
              <div class="h-1 bg-white/10 rounded-full overflow-hidden">
                <div class="h-full rounded-full" style="width: 85%; background: linear-gradient(to right, #009A44, rgba(0,154,68,0.4));"></div>
              </div>
              <div class="flex justify-between text-white/25 text-xs mt-1.5">
                <span>When caught late · low survival</span>
                <span>When caught early · 85%+ cured</span>
              </div>
            </div>
          </div>

          <!-- Right: vertical perch stat -->
          <div class="hidden lg:flex flex-col items-center gap-1 pb-1 animate-fade-in-up delay-200">
            <div class="w-px bg-gradient-to-b from-transparent via-white/20 to-white/20" style="height: 80px;"></div>
            <div class="text-center px-4 py-5 rounded-2xl border border-white/15" style="background: rgba(0,100,60,0.30); backdrop-filter: blur(16px);">
              <p class="text-white font-bold leading-none mb-1" style="font-family: var(--font-heading); font-size: 2.4rem; text-shadow: 0 2px 12px rgba(0,0,0,0.5);">4</p>
              <p class="text-[#4ade80] text-xs font-bold uppercase tracking-widest leading-tight">Key<br/>Signs</p>
            </div>
            <div class="w-px bg-gradient-to-b from-white/20 to-transparent" style="height: 40px;"></div>
          </div>
        </div>

        <!-- Bottom: four symptom pods -->
        <div class="grid grid-cols-2 lg:grid-cols-4 rounded-2xl overflow-hidden border border-white/12 animate-fade-in-up delay-200" style="background: rgba(0,0,0,0.28); backdrop-filter: blur(20px);">
          <div class="px-5 py-5 border-r border-white/10">
            <div class="w-6 h-0.5 bg-primary mb-3"></div>
            <p class="text-white font-bold text-xl leading-none mb-1" style="font-family: var(--font-heading);">Persistent<br/>Cough</p>
            <p class="text-primary text-xs font-bold uppercase tracking-wider mt-2 mb-1">Any duration</p>
            <p class="text-white/35 text-xs leading-relaxed">Coughing for 2+ weeks — don't wait</p>
          </div>
          <div class="px-5 py-5 border-r border-white/10">
            <div class="w-6 h-0.5 bg-[#003580] mb-3"></div>
            <p class="text-white font-bold text-xl leading-none mb-1" style="font-family: var(--font-heading);">Fever &<br/>Night Sweats</p>
            <p class="text-[#6ba3ff] text-xs font-bold uppercase tracking-wider mt-2 mb-1">Recurring</p>
            <p class="text-white/35 text-xs leading-relaxed">Persistent fever and drenching sweats</p>
          </div>
          <div class="px-5 py-5 border-r border-white/10 border-t lg:border-t-0 border-white/10">
            <div class="w-6 h-0.5 bg-[#009A44] mb-3"></div>
            <p class="text-white font-bold text-xl leading-none mb-1" style="font-family: var(--font-heading);">Weight<br/>Loss</p>
            <p class="text-[#4ade80] text-xs font-bold uppercase tracking-wider mt-2 mb-1">Unexplained</p>
            <p class="text-white/35 text-xs leading-relaxed">Rapid loss with no apparent cause</p>
          </div>
          <div class="px-5 py-5 flex flex-col justify-between border-t lg:border-t-0 border-white/10">
            <div>
              <div class="w-6 h-0.5 bg-[#f4a261] mb-3"></div>
              <p class="text-white font-bold text-xl leading-none mb-1" style="font-family: var(--font-heading);">Extreme<br/>Fatigue</p>
              <p class="text-[#f4a261] text-xs font-bold uppercase tracking-wider mt-2 mb-1">Persistent</p>
              <p class="text-white/35 text-xs leading-relaxed">Tiredness that rest can't fix</p>
            </div>
            <a href="/tb-questions-answers" class="mt-4 inline-flex items-center gap-2 text-primary text-xs font-bold uppercase tracking-widest hover:text-primary/70 transition-colors group">
              Learn More
              <svg class="w-3 h-3 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </a>
          </div>
        </div>

      </div>
    </div>

    <!-- ═══════════════ SLIDE 4 — HIV & TB ═══════════════ -->
    <div class="ss-slide" data-duration="9000">
      <div class="max-w-5xl mx-auto w-full">

        <!-- Top label bar -->
        <div class="flex items-center gap-4 mb-10 animate-fade-in-up">
          <img src="/logo.png" alt="TB Free Foundation of Namibia" class="h-8 w-auto opacity-80 drop-shadow-md shrink-0" />
          <div class="h-px flex-1 bg-white/15"></div>
          <p class="text-white/40 text-xs uppercase tracking-[0.22em] font-medium shrink-0">HIV–TB Co-infection · Namibia</p>
        </div>

        <!-- Hero editorial block -->
        <div class="grid grid-cols-1 lg:grid-cols-[1fr_160px] gap-6 items-end mb-8 animate-fade-in-up delay-100">
          <div>
            <div class="flex items-center gap-3 mb-4">
              <span class="block w-8 h-0.5 bg-primary"></span>
              <p class="text-primary text-xs font-bold uppercase tracking-[0.2em]">Critical Connection</p>
            </div>
            <div style="font-family: var(--font-heading);">
              <p class="text-white/45 text-xl sm:text-2xl font-normal leading-tight mb-1">People with HIV are</p>
              <p class="text-white font-bold leading-none mb-2" style="font-size: clamp(3.5rem, 9vw, 7rem); text-shadow: 0 4px 32px rgba(0,0,0,0.5);"><span data-count="20">20</span><span class="text-primary">×</span></p>
              <p class="text-white/60 text-2xl sm:text-3xl font-medium">more likely to <span class="text-white">develop TB</span></p>
            </div>
            <div class="mt-7 max-w-lg">
              <div class="flex items-center justify-between text-xs mb-2">
                <span class="text-white/40 uppercase tracking-wider">TB patients in Namibia also living with HIV</span>
                <span class="text-[#6ba8d4] font-bold text-sm">32%</span>
              </div>
              <div class="h-1 bg-white/10 rounded-full overflow-hidden">
                <div class="h-full rounded-full" style="width: 32%; background: linear-gradient(to right, #003580, rgba(0,53,128,0.4));"></div>
              </div>
              <div class="flex justify-between text-white/25 text-xs mt-1.5">
                <span>1 in 3 TB patients is co-infected</span>
                <span>Both must be treated together</span>
              </div>
            </div>
          </div>

          <!-- Right: vertical perch stat -->
          <div class="hidden lg:flex flex-col items-center gap-1 pb-1 animate-fade-in-up delay-200">
            <div class="w-px bg-gradient-to-b from-transparent via-white/20 to-white/20" style="height: 80px;"></div>
            <div class="text-center px-4 py-5 rounded-2xl border border-white/15" style="background: rgba(0,30,80,0.40); backdrop-filter: blur(16px);">
              <p class="text-white font-bold leading-none mb-1" style="font-family: var(--font-heading); font-size: 2rem; text-shadow: 0 2px 12px rgba(0,0,0,0.5);">#1</p>
              <p class="text-[#6ba8d4] text-xs font-bold uppercase tracking-widest leading-tight">Killer of<br/>PLHIV</p>
            </div>
            <div class="w-px bg-gradient-to-b from-white/20 to-transparent" style="height: 40px;"></div>
          </div>
        </div>

        <!-- Bottom 3-pod glass strip -->
        <div class="grid grid-cols-1 sm:grid-cols-3 rounded-2xl overflow-hidden border border-white/12 animate-fade-in-up delay-200" style="background: rgba(0,0,0,0.28); backdrop-filter: blur(20px);">
          <div class="px-5 py-5 border-r border-white/10">
            <div class="w-6 h-0.5 bg-primary mb-3"></div>
            <p class="text-white font-bold text-xl leading-none mb-1" style="font-family: var(--font-heading);">20× Higher<br/>TB Risk</p>
            <p class="text-primary text-xs font-bold uppercase tracking-wider mt-2 mb-1">Immune vulnerability</p>
            <p class="text-white/35 text-xs leading-relaxed">HIV destroys the cells that contain <em>M. tuberculosis</em>, turning latent TB into active disease</p>
          </div>
          <div class="px-5 py-5 border-r border-white/10">
            <div class="w-6 h-0.5 bg-[#003580] mb-3"></div>
            <p class="text-white font-bold text-xl leading-none mb-1" style="font-family: var(--font-heading);">32% of TB<br/>Patients</p>
            <p class="text-[#6ba8d4] text-xs font-bold uppercase tracking-wider mt-2 mb-1">Also have HIV</p>
            <p class="text-white/35 text-xs leading-relaxed">1 in 3 TB patients in Namibia is co-infected — both infections must be treated simultaneously</p>
          </div>
          <div class="px-5 py-5 flex flex-col justify-between">
            <div>
              <div class="w-6 h-0.5 bg-[#009A44] mb-3"></div>
              <p class="text-white font-bold text-xl leading-none mb-1" style="font-family: var(--font-heading);">85% Recover<br/>with Dual Tx</p>
              <p class="text-[#4ade80] text-xs font-bold uppercase tracking-wider mt-2 mb-1">ARV + TB treatment</p>
              <p class="text-white/35 text-xs leading-relaxed">Both ARV and TB treatment are <strong class="text-white/55">free</strong> at every Namibian MoHSS clinic</p>
            </div>
            <a href="/who-we-are" class="mt-4 inline-flex items-center gap-2 text-[#4ade80] text-xs font-bold uppercase tracking-widest hover:text-[#4ade80]/70 transition-colors group">
              Our Work
              <svg class="w-3 h-3 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </a>
          </div>
        </div>

      </div>
    </div>

    <!-- ═══════════════ SLIDE 5 — Workplace ═══════════════ -->
    <div class="ss-slide" data-duration="8000">
      <div class="max-w-5xl mx-auto w-full">

        <!-- Top label bar -->
        <div class="flex items-center gap-4 mb-10 animate-fade-in-up">
          <img src="/logo.png" alt="TB Free Foundation of Namibia" class="h-8 w-auto opacity-80 drop-shadow-md shrink-0" />
          <div class="h-px flex-1 bg-white/15"></div>
          <p class="text-white/40 text-xs uppercase tracking-[0.22em] font-medium shrink-0">Workplace Health · TB Prevention</p>
        </div>

        <!-- Hero editorial block -->
        <div class="grid grid-cols-1 lg:grid-cols-[1fr_200px] gap-6 items-center mb-8 animate-fade-in-up delay-100">
          <div>
            <div class="flex items-center gap-3 mb-4">
              <span class="block w-8 h-0.5 bg-[#6ba8d4]"></span>
