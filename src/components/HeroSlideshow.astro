            <div class="w-6 h-0.5 bg-[#6ba8d4] mb-3"></div>
            <p class="text-white font-bold text-xl leading-none mb-1" style="font-family: var(--font-heading);">87%<br/>Treatment Success</p>
            <p class="text-[#6ba8d4] text-xs font-bold uppercase tracking-wider mt-2 mb-1">Nationally</p>
            <p class="text-white/35 text-xs leading-relaxed">87% of TB patients in Namibia successfully complete treatment — free drugs at every MoHSS facility</p>
          </div>
          <div class="px-5 py-5 border-r border-white/10">
            <div class="w-6 h-0.5 bg-[#f4a261] mb-3"></div>
            <p class="text-white font-bold text-xl leading-none mb-1" style="font-family: var(--font-heading);">50,000+<br/>People Tested</p>
            <p class="text-[#f4a261] text-xs font-bold uppercase tracking-wider mt-2 mb-1">Through campaigns</p>
            <p class="text-white/35 text-xs leading-relaxed">Community outreach across all 14 Namibian regions — finding TB before it spreads</p>
          </div>
          <!-- image42 -->
          <div class="flex items-center justify-center p-3 min-h-[160px]">
            <img src="/images/image42.png" alt="YES! We Can End TB" class="w-full object-contain max-h-44 drop-shadow-2xl animate-img-breathe" />
          </div>
        </div>

      </div>
    </div>

  </div>

  <!-- Left arrow -->
  <button id="ss-prev" class="ss-arrow absolute left-4 sm:left-6 top-1/2 -translate-y-1/2 z-20" aria-label="Previous slide">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
  </button>

  <!-- Right arrow -->
  <button id="ss-next" class="ss-arrow absolute right-4 sm:right-6 top-1/2 -translate-y-1/2 z-20" aria-label="Next slide">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
  </button>

</section>

<script>
(function () {
  const stage = document.getElementById('ss-stage');
  const bgImg = document.getElementById('ss-bg-img') as HTMLImageElement;
  const tintEl = document.getElementById('ss-tint');
  const acc1El = document.getElementById('ss-acc1');
  const acc2El = document.getElementById('ss-acc2');
  const slides = Array.from(stage!.querySelectorAll<HTMLElement>('.ss-slide'));
  const prevBtn = document.getElementById('ss-prev');
  const nextBtn = document.getElementById('ss-next');
  const total = slides.length;
  let current = 0;
  let timer: ReturnType<typeof setTimeout> | null = null;

  const themes = [
    // slide 1: image43, dark overlay
    { img: '/images/image43.jpg', op: '1', tint: 'rgba(0,0,0,0.52)', a1: 'rgba(159,13,13,0.10)', a2: 'rgba(0,0,0,0)', pos: 'center center' },
    // slide 2: TB Facts — deep navy
    { img: null, op: '0', tint: 'rgba(10,10,26,0.92)', a1: 'rgba(0,53,128,0.22)', a2: 'rgba(0,53,128,0.10)', pos: 'center center' },
    // slide 3: Know the Signs — dark green
    { img: null, op: '0', tint: 'rgba(18,32,18,0.96)', a1: 'rgba(0,154,68,0.18)', a2: 'rgba(0,154,68,0.08)', pos: 'center center' },
    // slide 4: HIV & TB — very dark
    { img: null, op: '0', tint: 'rgba(14,6,6,0.96)', a1: 'rgba(159,13,13,0.20)', a2: 'rgba(0,53,128,0.10)', pos: 'center center' },
    // slide 5: Workplace — solid dark navy
    { img: null, op: '0', tint: 'rgba(6,10,26,0.96)', a1: 'rgba(0,53,128,0.28)', a2: 'rgba(0,30,80,0.16)', pos: 'center center' },
    // slide 6: Get Tested — solid dark green
    { img: null, op: '0', tint: 'rgba(6,22,10,0.96)', a1: 'rgba(0,154,68,0.22)', a2: 'rgba(0,100,50,0.14)', pos: 'center center' },
    // slide 7: Recovery — solid warm amber/yellow
    { img: null, op: '0', tint: 'rgba(32,20,2,0.96)', a1: 'rgba(244,162,97,0.34)', a2: 'rgba(200,120,20,0.16)', pos: 'center center' },
    // slide 8: Children — solid dark warm amber
    { img: null, op: '0', tint: 'rgba(28,14,4,0.96)', a1: 'rgba(244,162,97,0.30)', a2: 'rgba(200,100,20,0.14)', pos: 'center center' },
    // slide 9: Take Action — dark navy/purple
    { img: null, op: '0', tint: 'rgba(16,10,28,0.96)', a1: 'rgba(159,13,13,0.20)', a2: 'rgba(0,53,128,0.14)', pos: 'center center' },
  ];

  function applyTheme(idx: number) {
    const t = themes[idx];
    if (t.img) {
      bgImg!.src = t.img;
      bgImg!.style.opacity = t.op;
      bgImg!.style.objectFit = 'cover';
      bgImg!.style.objectPosition = t.pos || 'center center';
      bgImg!.style.transform = 'none';
    } else {
      bgImg!.style.opacity = '0';
    }
    tintEl!.style.background = t.tint;
    acc1El!.style.background = t.a1;
    acc2El!.style.background = t.a2;
  }

  function animateCounters(slide: HTMLElement) {
    slide.querySelectorAll<HTMLElement>('[data-count]').forEach(el => {
      const target = parseInt(el.dataset.count!, 10);
      const suffix = el.dataset.suffix || '';
      const prefix = '';
      const duration = 3400;
      const startTime = performance.now();
      function tick(now: number) {
        const progress = Math.min((now - startTime) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        const value = Math.round(target * eased);
        el.textContent = prefix + value.toLocaleString() + suffix;
        if (progress < 1) requestAnimationFrame(tick);
      }
      el.textContent = '0';
      requestAnimationFrame(tick);
    });
  }

  function goTo(idx: number) {
    const prev = current;
    current = ((idx % total) + total) % total;
    if (prev === current) return;

    const prevSlide = slides[prev];
    const nextSlide = slides[current];

    prevSlide.classList.add('fade-out');
    prevSlide.classList.remove('fade-in');
    setTimeout(() => {
      prevSlide.classList.remove('active', 'fade-out');
      applyTheme(current);
      nextSlide.classList.add('active');
      nextSlide.offsetHeight; // reflow
      nextSlide.classList.add('fade-in');
      animateCounters(nextSlide);
    }, 400);

    scheduleNext();
  }

  function scheduleNext() {
    if (timer) clearTimeout(timer);
    const dur = parseInt(slides[current].dataset.duration || '7500', 10);
    timer = setTimeout(() => goTo(current + 1), dur);
  }

  // Arrow clicks
  prevBtn!.addEventListener('click', () => { if (timer) clearTimeout(timer); goTo(current - 1); });
  nextBtn!.addEventListener('click', () => { if (timer) clearTimeout(timer); goTo(current + 1); });

  // Keyboard navigation
  document.addEventListener('keydown', e => {
    if (e.key === 'ArrowLeft') { if (timer) clearTimeout(timer); goTo(current - 1); }
    if (e.key === 'ArrowRight') { if (timer) clearTimeout(timer); goTo(current + 1); }
  });

  // Touch swipe
  let touchStartX = 0;
  stage!.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; }, { passive: true });
  stage!.addEventListener('touchend', e => {
    const delta = e.changedTouches[0].clientX - touchStartX;
    if (Math.abs(delta) > 50) { if (timer) clearTimeout(timer); goTo(current + (delta < 0 ? 1 : -1)); }
  }, { passive: true });

  // Init
  slides[0].classList.add('active', 'fade-in');
  applyTheme(0);
  animateCounters(slides[0]);
  scheduleNext();
})();
</script>
