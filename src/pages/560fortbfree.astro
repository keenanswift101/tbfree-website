---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
---

<Layout title="560forTBFree Campaign" description="560 to Break Barriers — Run, Walk, Cycle 560km over 6 weeks. Join the movement to end TB in Namibia.">
  <!-- Campaign Hero -->
  <section class="relative min-h-[70vh] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[#0f1419] via-[#1a2332] to-[#0f1419]"></div>
    <div class="absolute inset-0 opacity-20" style="background-image: repeating-linear-gradient(45deg, transparent, transparent 35px, rgba(159,13,13,0.15) 35px, rgba(159,13,13,0.15) 70px)"></div>
    <div class="relative z-10 text-center px-4 py-20">
      <div class="inline-flex items-center gap-2 bg-primary/20 border border-primary/40 px-4 py-1.5 rounded-full mb-6">
        <span class="w-2 h-2 bg-primary rounded-full animate-pulse"></span>
        <span class="text-primary text-xs font-bold uppercase tracking-widest">Live Campaign · 2026</span>
      </div>
      <h1 class="text-5xl sm:text-6xl lg:text-8xl font-black text-white mb-4" style="font-family: var(--font-heading); text-shadow: 3px 3px 0 rgba(159,13,13,0.5);">560 to Break Barriers</h1>
      <p class="text-xl sm:text-2xl text-white/70 font-medium tracking-wide mb-8">6 Weeks | 560 km | Run · Walk · Cycle</p>
      
      <!-- Fundraising Progress -->
      <div class="max-w-md mx-auto bg-white/5 border border-white/10 rounded-2xl p-6 mb-8">
        <div class="flex justify-between text-sm text-white/60 mb-2">
          <span>N$5,600.00 raised</span>
          <span>Goal: N$80,000</span>
        </div>
        <div class="w-full h-3 bg-white/10 rounded-full overflow-hidden mb-2">
          <div class="h-full bg-primary rounded-full transition-all duration-1000" style="width: 7%"></div>
        </div>
        <p class="text-white/40 text-xs">7% of goal reached</p>
      </div>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/donations" class="px-8 py-3.5 bg-primary text-white font-bold rounded-lg hover:bg-primary/90 transition-all text-sm uppercase tracking-wider">
          Donate Now
        </a>
        <a href="#how-to-participate" class="px-8 py-3.5 bg-white/10 text-white font-semibold rounded-lg hover:bg-white/20 transition-all text-sm border border-white/20">
          How to Participate
        </a>
      </div>
    </div>
  </section>

  <!-- The Story -->
  <section class="py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto">
      <SectionHeading
        title="The Story Behind 560"
        subtitle="A TB survivor's journey to break barriers"
        centered
      />
      <div class="mt-10 bg-gray-50 rounded-2xl p-8 sm:p-12 border-l-4 border-primary">
        <p class="text-gray-700 text-lg leading-relaxed mb-6">
          <strong class="text-gray-900">I'm a TB survivor.</strong> I know the barriers firsthand — stigma, late diagnosis, treatment gaps, and poverty.
        </p>
        <p class="text-gray-700 text-lg leading-relaxed mb-6">
          <strong class="text-gray-900">I'm running 560 km</strong> over 6 weeks and pledging <strong class="text-gray-900">N$10 per kilometre</strong> to TB Free Foundation Namibia.
        </p>
        <p class="text-gray-700 text-lg leading-relaxed">
          Now I'm challenging <strong class="text-gray-900">Corporate Namibia</strong> and <strong class="text-gray-900">100 individuals</strong> to join me. Together, we can break the barriers that stop people from getting the care they need.
        </p>
      </div>
    </div>
  </section>

  <!-- Three Challenges -->
  <section id="how-to-participate" class="py-20 px-4 sm:px-6 lg:px-8 bg-gray-50">
    <div class="max-w-7xl mx-auto">
      <SectionHeading
        title="Three Ways to Join the Fight"
        subtitle="Choose how you want to break barriers against TB in Namibia."
        centered
      />

      <div class="grid lg:grid-cols-3 gap-8 mt-12">

        <!-- Card 1: Corporate Challenge -->
        <div class="group rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 border border-gray-100">
          <div class="relative p-8 text-center" style="background: linear-gradient(135deg, #0f1419 0%, #1a2332 100%); min-height: 280px;">
            <div class="absolute inset-0 opacity-10" style="background: linear-gradient(45deg, transparent 30%, rgba(220,38,38,0.3) 50%, transparent 70%);"></div>
            <div class="relative z-10">
              <span class="inline-block text-xs font-bold text-primary uppercase tracking-widest mb-4 bg-primary/10 px-3 py-1 rounded-full">Corporate Challenge</span>
              <h3 class="text-3xl font-black text-white mb-2" style="font-family: var(--font-heading);">CAN YOUR COMPANY</h3>
              <h3 class="text-3xl font-black text-white mb-4" style="font-family: var(--font-heading);">MATCH OR BEAT</h3>
              <p class="text-5xl font-black text-primary mb-3" style="text-shadow: 0 0 30px rgba(159,13,13,0.5);">N$5,600?</p>
              <p class="text-white/70 text-sm">That's my personal pledge. Will you join the fight?</p>
            </div>
          </div>
          <div class="bg-white p-6">
            <h4 class="font-bold text-gray-900 mb-3">Your N$5,600 Funds:</h4>
            <ul class="space-y-2 text-sm text-gray-600 mb-6">
              <li class="flex items-start gap-2"><span class="text-primary font-bold mt-0.5">✓</span> Community TB screening campaigns</li>
              <li class="flex items-start gap-2"><span class="text-primary font-bold mt-0.5">✓</span> Transport for 50 patients to attend treatment</li>
              <li class="flex items-start gap-2"><span class="text-primary font-bold mt-0.5">✓</span> Nutritional support for TB families</li>
              <li class="flex items-start gap-2"><span class="text-primary font-bold mt-0.5">✓</span> Training for community health workers</li>
              <li class="flex items-start gap-2"><span class="text-primary font-bold mt-0.5">✓</span> Research to improve TB care in Namibia</li>
            </ul>
            <a href="/donations" class="block w-full text-center bg-[#1a2332] text-white font-bold py-3 rounded-lg hover:bg-[#0f1419] transition-colors text-sm">
              Take the Corporate Challenge
            </a>
          </div>
        </div>

        <!-- Card 2: 100 Individuals Challenge -->
        <div class="group rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 border border-gray-100">
          <div class="relative p-8 text-center" style="background: linear-gradient(to bottom, #fef3c7 0%, #fde68a 50%, #fbbf24 100%); min-height: 280px;">
            <div class="relative z-10">
              <span class="inline-block text-xs font-bold text-amber-800 uppercase tracking-widest mb-4 bg-white/60 px-3 py-1 rounded-full">Individual Challenge</span>
              <h3 class="text-3xl font-black text-amber-900 mb-4" style="font-family: var(--font-heading);">BE ONE OF 100</h3>
              <p class="text-8xl font-black text-amber-600 mb-2" style="text-shadow: 3px 3px 0 rgba(217,119,6,0.2);">100</p>
              <p class="text-2xl font-bold text-amber-800 mb-1">INDIVIDUALS</p>
              <p class="text-amber-700 font-semibold">Each Donating <span class="text-3xl font-black text-amber-600">N$560</span></p>
              <p class="text-amber-800 text-sm font-semibold mt-2">Together We Raise N$56,000</p>
            </div>
          </div>
          <div class="bg-white p-6">
            <h4 class="font-bold text-gray-900 mb-3">Every N$560 You Give Helps:</h4>
            <ul class="space-y-2 text-sm text-gray-600 mb-6">
              <li class="flex items-start gap-2"><span class="text-amber-500 mt-0.5">💛</span> Provide transport for TB patients to reach treatment</li>
              <li class="flex items-start gap-2"><span class="text-amber-500 mt-0.5">💛</span> Fund nutritional support for families affected by TB</li>
              <li class="flex items-start gap-2"><span class="text-amber-500 mt-0.5">💛</span> Support community TB screening and awareness</li>
              <li class="flex items-start gap-2"><span class="text-amber-500 mt-0.5">💛</span> Train volunteers to care for TB patients</li>
              <li class="flex items-start gap-2"><span class="text-amber-500 mt-0.5">💛</span> Break the stigma that keeps people silent</li>
            </ul>
            <a href="/donations" class="block w-full text-center bg-amber-500 text-white font-bold py-3 rounded-lg hover:bg-amber-600 transition-colors text-sm">
              Be One of 100 — Donate N$560
            </a>
          </div>
        </div>

        <!-- Card 3: Volunteer Challenge -->
        <div class="group rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 border border-gray-100">
          <div class="relative p-8 text-center" style="background: linear-gradient(to bottom, #d5f4e6 0%, #80ced7 50%, #5eaaa8 100%); min-height: 280px;">
            <div class="relative z-10">
              <span class="inline-block text-xs font-bold text-emerald-900 uppercase tracking-widest mb-4 bg-white/60 px-3 py-1 rounded-full">Volunteer Challenge</span>
              <h3 class="text-3xl font-black text-emerald-900 mb-4" style="font-family: var(--font-heading);">Give 56 Minutes</h3>
              <p class="text-8xl font-black text-emerald-700 mb-2">56</p>
              <p class="text-2xl font-bold text-emerald-800 mb-1">MINUTES</p>
              <p class="text-emerald-800 text-sm font-semibold">Spend time with a TB patient<br/>and help them heal</p>
            </div>
          </div>
          <div class="bg-white p-6">
            <h4 class="font-bold text-gray-900 mb-3">How You Can Help:</h4>
            <ul class="space-y-2 text-sm text-gray-600 mb-6">
              <li class="flex items-start gap-2"><span class="mt-0.5">🌱</span> Start a container garden at their home</li>
              <li class="flex items-start gap-2"><span class="mt-0.5">🌱</span> Share a meal and conversation</li>
              <li class="flex items-start gap-2"><span class="mt-0.5">🌱</span> Help with household chores or errands</li>
              <li class="flex items-start gap-2"><span class="mt-0.5">🌱</span> Teach a skill or hobby</li>
              <li class="flex items-start gap-2"><span class="mt-0.5">🌱</span> Simply sit, listen, and be present</li>
            </ul>
            <a href="/volunteer" class="block w-full text-center bg-emerald-600 text-white font-bold py-3 rounded-lg hover:bg-emerald-700 transition-colors text-sm">
              Volunteer Your Time
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why This Matters -->
  <section class="py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto">
      <div class="bg-gradient-to-br from-[#1a1a2e] to-[#111827] rounded-2xl p-10 sm:p-14">
        <h2 class="text-3xl font-bold text-white mb-6" style="font-family: var(--font-heading);">Why This Matters</h2>
        <p class="text-white/80 text-lg leading-relaxed mb-6">
          TB patients often face isolation, stigma, and loneliness during treatment. Your presence, your time, your financial support, and your compassion can be as healing as medicine.
        </p>
        <p class="text-white/80 text-lg leading-relaxed mb-8">
          Namibia has one of the highest TB burdens in the world. Together, through the 560forTBFree campaign, we can change that — one kilometre, one donation, one hour at a time.
        </p>
        <div class="grid sm:grid-cols-3 gap-6 text-center">
          <div class="bg-white/5 rounded-xl p-6 border border-white/10">
            <p class="text-4xl font-black text-primary mb-2">560</p>
            <p class="text-white/60 text-sm">Kilometres to Run</p>
          </div>
          <div class="bg-white/5 rounded-xl p-6 border border-white/10">
            <p class="text-4xl font-black text-amber-400 mb-2">100</p>
            <p class="text-white/60 text-sm">Individuals Needed</p>
          </div>
          <div class="bg-white/5 rounded-xl p-6 border border-white/10">
            <p class="text-4xl font-black text-emerald-400 mb-2">56</p>
            <p class="text-white/60 text-sm">Minutes to Give</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 px-4 sm:px-6 lg:px-8 bg-primary">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-6" style="font-family: var(--font-heading);">
        Break Barriers. Save Lives.
      </h2>
      <p class="text-white/80 text-lg mb-8">
        TB Free Foundation Namibia | Section 21 Not-for-Profit
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/donations" class="px-8 py-3.5 bg-white text-primary font-bold rounded-lg hover:bg-gray-100 transition-all text-sm">
          Donate Now
        </a>
        <a href="/contact" class="px-8 py-3.5 bg-white/10 text-white font-semibold rounded-lg hover:bg-white/20 transition-all text-sm border border-white/30">
          Contact Us
        </a>
      </div>
    </div>
  </section>
</Layout>
