---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
---

<Layout title="Donate" description="Support TB Free Foundation of Namibia. Your donation helps us fight tuberculosis, support patients, and build TB-free communities.">
  <Hero
    title="Support Our Cause"
    subtitle="Your generous contribution helps us continue the fight against tuberculosis in Namibia."
    height="small"
  />

  <!-- Why Donate -->
  <section class="py-24 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16 observe-animate" data-animate="animate-fade-in-up">
        <SectionHeading
          title="Why Your Support Matters"
          subtitle="Every donation directly contributes to saving lives and building a TB-free Namibia."
          centered
        />
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          {
            title: 'Community Outreach',
            description: 'Fund healthcare workers reaching remote and marginalized communities across Namibia.',
            icon: 'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z'
          },
          {
            title: 'TB Champion Training',
            description: 'Equip community champions with knowledge and tools to fight TB locally.',
            icon: 'M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z'
          },
          {
            title: 'Awareness Campaigns',
            description: 'Support education programs that break down TB stigma and encourage early testing.',
            icon: 'M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z'
          },
          {
            title: 'Equipment & Resources',
            description: 'Provide essential tools like e-bikes and medical supplies to healthcare facilities.',
            icon: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z'
          }
        ].map((item, index) => (
          <div class="observe-animate bg-white rounded-xl p-6 text-center shadow-sm border border-gray-100 hover:shadow-lg hover:-translate-y-1 transition-all duration-300" data-animate="animate-fade-in-up" style={`animation-delay: ${index * 0.1}s`}>
            <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
              </svg>
            </div>
            <h3 class="font-semibold text-gray-900 mb-2">{item.title}</h3>
            <p class="text-sm text-gray-600 leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Banking Details -->
  <section class="py-24 px-4 sm:px-6 lg:px-8 bg-gray-50">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12 observe-animate" data-animate="animate-fade-in-up">
        <SectionHeading
          title="How to Donate"
          subtitle="You can make a monetary donation via bank transfer using the details below."
          centered
        />
      </div>

      <div class="observe-animate" data-animate="animate-scale-in">
        <div class="bg-white rounded-2xl p-10 sm:p-12 max-w-2xl mx-auto shadow-sm border border-gray-100">
          <div class="text-center mb-8">
            <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900">Bank Transfer Details</h3>
          </div>

          <div class="space-y-4">
            <div class="flex justify-between items-center py-3 border-b border-gray-100">
              <span class="text-sm text-gray-500">Account Name</span>
              <span class="text-sm font-medium text-gray-900">TB Free Foundation of Namibia</span>
            </div>
            <div class="flex justify-between items-center py-3 border-b border-gray-100">
              <span class="text-sm text-gray-500">Bank</span>
              <span class="text-sm font-medium text-gray-900">First National Bank (FNB) Namibia</span>
            </div>
            <div class="flex justify-between items-center py-3 border-b border-gray-100">
              <span class="text-sm text-gray-500">Account Number</span>
              <span class="text-sm font-medium text-gray-900">62940710896</span>
            </div>
            <div class="flex justify-between items-center py-3 border-b border-gray-100">
              <span class="text-sm text-gray-500">Branch Code</span>
              <span class="text-sm font-medium text-gray-900">282 672</span>
            </div>
            <div class="flex justify-between items-center py-3 border-b border-gray-100">
              <span class="text-sm text-gray-500">Account Type</span>
              <span class="text-sm font-medium text-gray-900">Cheque Account</span>
            </div>
            <div class="flex justify-between items-center py-3">
              <span class="text-sm text-gray-500">Reference</span>
              <span class="text-sm font-medium text-gray-900">Your Name + "Donation"</span>
            </div>
          </div>

          <div class="mt-8 p-4 bg-primary/5 rounded-lg">
            <p class="text-xs text-gray-600 leading-relaxed text-center">
              Please use your name followed by "Donation" as the payment reference. After making your donation, kindly email proof of payment to
              <a href="mailto:admin@tbfreenamibia.com" class="text-primary font-medium">admin@tbfreenamibia.com</a>
              so that we can acknowledge your generous contribution.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Alternative ways to help -->
  <section class="py-24 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <SectionHeading
        title="Other Ways to Help"
        subtitle="Beyond monetary donations, there are many ways you can support our mission."
        centered
      />

      <div class="grid sm:grid-cols-3 gap-8 mt-12">
        <div class="bg-white rounded-xl p-8 text-center shadow-sm border border-gray-100 hover:shadow-lg transition-all duration-300">
          <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900 mb-2">Volunteer</h3>
          <p class="text-sm text-gray-600 leading-relaxed mb-4">
            Join us as a volunteer and contribute your time and skills to our community outreach programs.
          </p>
          <a href="/contact" class="text-sm text-primary font-medium hover:text-primary-dark transition-colors">
            Get in touch
          </a>
        </div>

        <div class="bg-white rounded-xl p-8 text-center shadow-sm border border-gray-100 hover:shadow-lg transition-all duration-300">
          <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900 mb-2">Partner With Us</h3>
          <p class="text-sm text-gray-600 leading-relaxed mb-4">
            Organizations and businesses can partner with us to expand our impact across Namibia.
          </p>
          <a href="/contact" class="text-sm text-primary font-medium hover:text-primary-dark transition-colors">
            Explore partnerships
          </a>
        </div>

        <div class="bg-white rounded-xl p-8 text-center shadow-sm border border-gray-100 hover:shadow-lg transition-all duration-300">
          <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z" />
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900 mb-2">Spread the Word</h3>
          <p class="text-sm text-gray-600 leading-relaxed mb-4">
            Help us raise awareness by sharing our mission with your network and community.
          </p>
          <a href="/events" class="text-sm text-primary font-medium hover:text-primary-dark transition-colors">
            See our events
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Tax Note -->
  <section class="py-16 px-4 sm:px-6 lg:px-8 bg-gray-50">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-sm text-gray-500 leading-relaxed">
        TB Free Foundation of Namibia is a registered not-for-profit civil society organization.
        For enquiries about donations, tax certificates, or corporate partnerships, please contact us at
        <a href="mailto:admin@tbfreenamibia.com" class="text-primary font-medium">admin@tbfreenamibia.com</a>.
      </p>
    </div>
  </section>
</Layout>
