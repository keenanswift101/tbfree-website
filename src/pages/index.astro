---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
---

<Layout title="Home">
  <!-- Hero Section -->
  <Hero
    title="Breaking Barriers to END TB"
    subtitle="The TB Free Foundation of Namibia is dedicated to the fight against tuberculosis and the creation of a world free from the disease."
    height="full"
    backgroundImage="/images/hero-home.jpg"
  >
    <div class="flex flex-col sm:flex-row gap-4 justify-center mt-10 animate-fade-in-up delay-400">
      <a href="/who-we-are" class="px-8 py-3.5 bg-white text-primary font-semibold rounded-lg hover:bg-gray-100 transition-all duration-200 text-sm">
        Learn About Us
      </a>
      <a href="/donations" class="px-8 py-3.5 bg-primary text-white font-semibold rounded-lg hover:bg-primary-dark transition-all duration-200 text-sm border border-white/20">
        Support Our Cause
      </a>
    </div>
  </Hero>

  <!-- About Section -->
  <section class="py-24 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="observe-animate" data-animate="animate-slide-left">
          <SectionHeading
            title="The TB Free Foundation of Namibia"
            subtitle="A not-for-profit civil society organization established to work collaboratively towards the END TB goals and advocate for TB patients throughout Namibia."
          />
          <p class="text-gray-600 leading-relaxed mb-6">
            The TB Free Foundation is dedicated to addressing the complex challenges of TB through community engagement, research, policy advocacy, and patient support. We collaborate with a wide range of stakeholders, from local communities to government leaders, ensuring that our efforts have the broadest possible impact.
          </p>
          <p class="text-gray-600 leading-relaxed mb-8">
            Together, we can create a Namibia and a world free of tuberculosis, where everyone has the right to health and dignity.
          </p>
          <a href="/who-we-are" class="inline-flex items-center gap-2 text-primary font-medium hover:gap-3 transition-all duration-200">
            Learn more about us
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
        <div class="observe-animate" data-animate="animate-slide-right">
          <div class="relative">
            <div class="glass-card rounded-2xl p-8">
              <img
                src="/images/about-home.jpg"
                alt="TB Free Foundation team members working in the community"
                class="w-full h-80 object-cover rounded-xl"
                loading="lazy"
              />
            </div>
            <div class="absolute -bottom-6 -left-6 glass-primary rounded-xl p-6 max-w-xs">
              <p class="text-sm font-semibold text-primary">Founded by a TB survivor</p>
              <p class="text-xs text-gray-600 mt-1">Fighting every day for those who do not have a voice</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Key Focus Areas -->
  <section class="py-24 px-4 sm:px-6 lg:px-8 bg-gray-50">
    <div class="max-w-7xl mx-auto">
      <div class="text-center observe-animate" data-animate="animate-fade-in-up">
        <SectionHeading
          title="What We Stand For"
          subtitle="Our work is rooted in advocacy, education, and community empowerment to fight TB at every level."
          centered
        />
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8 mt-4">
        {[
          {
            title: 'Patient Advocacy',
            description: 'We actively support TB patients, ensuring equitable access to healthcare, diagnostics, and treatment across Namibia.',
            icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z'
          },
          {
            title: 'Community Engagement',
            description: 'We train TB champions and mobilize communities to raise awareness, educate, and reduce stigma around tuberculosis.',
            icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z'
          },
          {
            title: 'Research & Innovation',
            description: 'We develop and support innovative strategies and community-based approaches to improve TB care and treatment outcomes.',
            icon: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z'
          },
          {
            title: 'Policy Engagement',
            description: 'We engage with policymakers to ensure TB patients\' rights are protected and push for equitable access to healthcare.',
            icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4'
          },
          {
            title: 'Awareness & Education',
            description: 'We increase awareness about TB through strategic campaigns, educational programs, and survivor stories that break down stigma.',
            icon: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253'
          },
          {
            title: 'Reaching the Vulnerable',
            description: 'We facilitate outreach to marginalized and vulnerable populations, extending healthcare access to those who would otherwise be overlooked.',
            icon: 'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z'
          }
        ].map((item, index) => (
          <div class="observe-animate glass-card rounded-xl p-8 hover:shadow-lg hover:-translate-y-1 transition-all duration-300" data-animate="animate-fade-in-up" style={`animation-delay: ${index * 0.1}s`}>
            <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 mb-3">{item.title}</h3>
            <p class="text-sm text-gray-600 leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- World TB Day Section -->
  <section class="py-24 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <div class="relative rounded-2xl overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-primary via-primary-dark to-gray-900">
          <img
            src="/images/world-tb-day.jpg"
            alt="World TB Day commemoration event"
            class="w-full h-full object-cover opacity-20"
            loading="lazy"
          />
        </div>
        <div class="relative z-10 p-12 sm:p-16 lg:p-20">
          <div class="max-w-2xl">
            <p class="text-white/60 text-sm uppercase tracking-wider mb-4">Every Year on 24 March</p>
            <h2 class="text-3xl sm:text-4xl font-bold text-white mb-6" style="font-family: var(--font-heading);">
              World TB Day
            </h2>
            <p class="text-white/80 leading-relaxed mb-8">
              Each year we commemorate World TB Day to raise public awareness about the devastating health, social and economic consequences of tuberculosis and to step up efforts to end the global TB epidemic.
            </p>
            <a href="/events" class="inline-flex items-center gap-2 px-6 py-3 bg-white text-primary font-semibold rounded-lg hover:bg-gray-100 transition-all duration-200 text-sm">
              View Our Events
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-24 px-4 sm:px-6 lg:px-8 bg-gray-50">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-6" style="font-family: var(--font-heading);">
        Actively Changing the TB Health Game
      </h2>
      <p class="text-lg text-gray-600 leading-relaxed mb-10 max-w-2xl mx-auto">
        Join us in our mission to create a Namibia free of tuberculosis. Every contribution, every voice, and every action counts in the fight against TB.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="px-8 py-3.5 bg-primary text-white font-semibold rounded-lg hover:bg-primary-dark transition-all duration-200 text-sm">
          Get Involved
        </a>
        <a href="/donations" class="px-8 py-3.5 bg-white text-gray-900 font-semibold rounded-lg hover:bg-gray-100 transition-all duration-200 text-sm border border-gray-200">
          Make a Donation
        </a>
      </div>
    </div>
  </section>
</Layout>
