---
import Layout from '../layouts/Layout.astro';
import HeroSlideshow from '../components/HeroSlideshow.astro';
import SectionHeading from '../components/SectionHeading.astro';
---

<Layout title="Home">
  <!-- ═══════════════════ HERO SLIDESHOW ═══════════════════ -->
  <HeroSlideshow />

  <!-- Fundraising Floating Icon + Expandable Card (fixed position, page-level) -->
  <button id="fundraising-toggle" class="fixed left-5 bottom-6 z-40 group" aria-label="Open fundraising panel">
    <span class="absolute inset-0 rounded-full bg-primary/30 animate-ping"></span>
    <span class="absolute -inset-1 rounded-full bg-primary/20 animate-pulse"></span>
    <span class="relative flex items-center justify-center w-14 h-14 bg-primary rounded-full shadow-lg shadow-primary/40 text-white group-hover:scale-110 transition-transform duration-200 text-2xl font-bold">$</span>
    <span class="absolute -top-1 -right-1 flex items-center justify-center w-5 h-5 bg-amber-400 text-[10px] font-bold text-gray-900 rounded-full">7%</span>
  </button>

  <div id="fundraising-panel" class="fixed left-5 bottom-24 z-40 w-72 opacity-0 scale-90 pointer-events-none transition-all duration-300 origin-bottom-left">
    <div class="bg-[#1a1a2e] rounded-2xl shadow-2xl overflow-hidden border border-white/10">
      <div class="bg-primary px-5 py-4 flex items-center justify-between">
        <div class="flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-white animate-pulse"></span>
          <span class="text-white text-xs font-bold uppercase tracking-wider">Live Fundraising</span>
        </div>
        <button id="fundraising-close" class="text-white/70 hover:text-white transition-colors" aria-label="Close panel">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <div class="px-5 py-4 space-y-4">
        <div>
          <span class="text-xs text-primary font-semibold uppercase tracking-wider">Live · 2026</span>
          <h4 class="text-white font-bold text-sm mt-1 leading-snug">560forTBFree</h4>
          <p class="text-white/60 text-xs mt-1 leading-relaxed">Join our flagship fundraising campaign to support TB patients across Namibia. Every contribution counts!</p>
          <div class="mt-3">
            <div class="flex justify-between text-xs text-white/50 mb-1">
              <span>N$5,600.00 raised</span>
              <span>Goal: N$80,000</span>
            </div>
            <div class="w-full h-2 bg-white/10 rounded-full overflow-hidden">
              <div class="h-full bg-primary rounded-full transition-all duration-500" style="width: 7%"></div>
            </div>
            <p class="text-white/40 text-xs mt-2 text-right">7% of goal reached</p>
          </div>
        </div>
      </div>
      <div class="px-5 pb-5">
        <a href="/560fortbfree" class="block w-full text-center bg-primary text-white text-sm font-bold py-3 rounded-lg hover:bg-primary/90 transition-colors">
          Donate to 560forTBFree
        </a>
      </div>
    </div>
  </div>

  <script>
    const fundraisingToggle = document.getElementById('fundraising-toggle');
    const fundraisingPanel = document.getElementById('fundraising-panel');
    const fundraisingClose = document.getElementById('fundraising-close');
    let fundraisingOpen = false;

    function toggleFundraising(open: boolean) {
      fundraisingOpen = open;
      if (open) {
        fundraisingToggle?.classList.add('opacity-0', 'pointer-events-none', 'scale-75');
        fundraisingPanel?.classList.remove('opacity-0', 'scale-90', 'pointer-events-none');
        fundraisingPanel?.classList.add('opacity-100', 'scale-100');
      } else {
        fundraisingPanel?.classList.add('opacity-0', 'scale-90', 'pointer-events-none');
        fundraisingPanel?.classList.remove('opacity-100', 'scale-100');
        fundraisingToggle?.classList.remove('opacity-0', 'pointer-events-none', 'scale-75');
      }
    }

    fundraisingToggle?.classList.add('transition-all', 'duration-300');
    fundraisingToggle?.addEventListener('click', () => toggleFundraising(true));
    fundraisingClose?.addEventListener('click', () => toggleFundraising(false));
  </script>

  <!-- About Section -->
  <section class="py-24 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="observe-animate" data-animate="animate-slide-left">
          <SectionHeading
            title="The TB Free Foundation of Namibia"
            subtitle="A not-for-profit civil society organization established to work collaboratively towards the END TB goals and advocate for TB patients throughout Namibia."
          />
          <p class="text-gray-600 leading-relaxed mb-6">
            The organization is dedicated to the fight against tuberculosis (TB) and the creation of a world free from the disease. Our mission is deeply rooted in advocating for the rights of TB patients, ensuring equitable access to healthcare, diagnostics, and treatment, and increasing awareness and education about TB in our communities.
          </p>
          <p class="text-gray-600 leading-relaxed mb-8">
            Founded by a TB survivor who faced stigma and isolation, we fight every day for those who do not have a voice.
          </p>
          <a href="/who-we-are" class="inline-flex items-center gap-2 text-primary font-medium hover:gap-3 transition-all duration-200">
            Learn more about us
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
        <div class="observe-animate" data-animate="animate-slide-right">
          <div class="rounded-2xl overflow-hidden shadow-xl">
            <img
              src="/images/image11.png"
              alt="Karin Husselmann - TB survivor and founder of TB Free Foundation Namibia"
              class="w-full h-auto object-contain"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Key Focus Areas -->
  <section class="py-24 px-4 sm:px-6 lg:px-8 bg-gray-50">
    <div class="max-w-7xl mx-auto">
      <div class="text-center observe-animate" data-animate="animate-fade-in-up">
        <SectionHeading
          title="What We Stand For"
          subtitle="Our work is rooted in advocacy, education, and community empowerment to fight TB at every level."
          centered
        />
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8 mt-4">
        {[
          {
            title: 'Patient Advocacy',
            description: 'We actively support TB patients, ensuring equitable access to healthcare, diagnostics, and treatment across Namibia.',
            icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z'
          },
          {
            title: 'Community Engagement',
            description: 'We train TB champions and mobilize communities to raise awareness, educate, and reduce stigma around tuberculosis.',
            icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z'
          },
          {
            title: 'Research & Innovation',
            description: 'We develop and support innovative strategies and community-based approaches to improve TB care and treatment outcomes.',
            icon: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z'
          },
          {
            title: 'Policy Engagement',
            description: 'We engage with policymakers to ensure TB patients\' rights are protected and push for equitable access to healthcare.',
            icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4'
          },
          {
            title: 'Awareness & Education',
            description: 'We increase awareness about TB through strategic campaigns, educational programs, and survivor stories that break down stigma.',
            icon: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253'
          },
          {
            title: 'Reaching the Vulnerable',
            description: 'We facilitate outreach to marginalized and vulnerable populations, extending healthcare access to those who would otherwise be overlooked.',
            icon: 'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z'
          }
        ].map((item, index) => (
          <div class="observe-animate bg-white rounded-xl p-8 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 border border-gray-100" data-animate="animate-fade-in-up" style={`animation-delay: ${index * 0.1}s`}>
            <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 mb-3">{item.title}</h3>
            <p class="text-sm text-gray-600 leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Image Gallery Section - Events Highlight -->
  <section class="py-24 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <div class="text-center observe-animate" data-animate="animate-fade-in-up">
        <SectionHeading
          title="Our Impact in Action"
          subtitle="We were proud to stand alongside the Ministry of Health and Social Services at the World TB Day commemoration in Lüderitz, Namibia, in 2025, renewing our collective commitment to ending tuberculosis by 2030."
          centered
        />
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mt-12">
        <div class="rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-shadow duration-300">
          <img src="/images/image5.1.png" alt="TB Free Foundation community outreach" class="w-full h-64 object-cover" loading="lazy" />
        </div>
        <div class="rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-shadow duration-300">
          <img src="/images/image9.1.png" alt="TB Free Foundation advocacy event" class="w-full h-64 object-cover" loading="lazy" />
        </div>
        <div class="rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-shadow duration-300">
          <img src="/images/image10.png" alt="TB Free Foundation team engagement" class="w-full h-64 object-cover" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- E-Bike Donation Section -->
  <section class="py-24 px-4 sm:px-6 lg:px-8 bg-gray-50">
    <div class="max-w-7xl mx-auto">
      <div class="text-center observe-animate" data-animate="animate-fade-in-up">
        <SectionHeading
          title="Community Projects"
          subtitle="Tsumkwe, in the Otjozondjupa region, carries one of the heaviest burdens of drug-resistant TB in Namibia. In 2023, the TB Free Foundation responded by donating two GPS-equipped e-bikes to community health workers — giving them the mobility they need to follow up with patients and keep people connected to care."
          centered
        />
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mt-12">
        <div class="rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-shadow duration-300 bg-gray-200 h-72 flex items-center justify-center">
          <div class="text-center text-gray-400">
            <svg class="w-12 h-12 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
            <span class="text-sm font-medium">Photo coming soon</span>
          </div>
        </div>
        <div class="rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-shadow duration-300">
          <img src="/images/image4.png" alt="TB Free Foundation community outreach" class="w-full h-72 object-cover" loading="lazy" />
        </div>
        <div class="rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-shadow duration-300 bg-gray-200 h-72 flex items-center justify-center">
          <div class="text-center text-gray-400">
            <svg class="w-12 h-12 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
            <span class="text-sm font-medium">Photo coming soon</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- World TB Day Section -->
  <section class="py-24 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <div class="relative rounded-2xl overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-[#1a1a2e] via-primary-dark to-[#1a1a2e]">
          <img
            src="/images/tbfreenam.png"
            alt="World TB Day commemoration event"
            class="w-full h-full object-cover opacity-20"
            loading="lazy"
          />
        </div>
        <div class="relative z-10 p-12 sm:p-16 lg:p-20">
          <div class="max-w-2xl">
            <p class="text-white/60 text-sm uppercase tracking-wider mb-4">Every Year on 24 March</p>
            <h2 class="text-3xl sm:text-4xl font-bold text-white mb-6" style="font-family: var(--font-heading);">
              World TB Day
            </h2>
            <p class="text-white/80 leading-relaxed mb-8">
              Each year we commemorate World TB Day to raise public awareness about the devastating health, social and economic consequences of tuberculosis and to step up efforts to end the global TB epidemic.
            </p>
            <a href="/world-tb-day" class="inline-flex items-center gap-2 px-6 py-3 bg-white text-primary font-semibold rounded-lg hover:bg-gray-100 transition-all duration-200 text-sm">
              Learn More
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-24 px-4 sm:px-6 lg:px-8 bg-gray-50">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-6" style="font-family: var(--font-heading);">
        Actively Changing the TB Game
      </h2>
      <p class="text-lg text-gray-600 leading-relaxed mb-10 max-w-2xl mx-auto">
        Join us in our mission to create a Namibia free of tuberculosis. Every contribution, every voice, and every action counts in the fight against TB.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="px-8 py-3.5 bg-primary text-white font-semibold rounded-lg hover:bg-primary-dark transition-all duration-200 text-sm">
          Get Involved
        </a>
        <a href="/donations" class="px-8 py-3.5 bg-white text-gray-900 font-semibold rounded-lg hover:bg-gray-100 transition-all duration-200 text-sm border border-gray-200">
          Make a Donation
        </a>
      </div>
    </div>
  </section>

  <!-- Floating Chat Widget -->
  <div id="chat-widget" class="fixed bottom-6 right-6 z-50 flex flex-col items-end gap-3">
    <!-- Chat Panel -->
    <div id="chat-panel" class="hidden w-80 rounded-2xl shadow-2xl overflow-hidden border border-white/10 flex flex-col" style="background: #1a1a2e; max-height: 480px;">
      <!-- Header -->
      <div class="bg-primary px-4 py-3.5 flex items-center justify-between flex-shrink-0">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-full bg-white/20 flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path d="M18 10c0 3.866-3.582 7-8 7a8.841 8.841 0 01-4.083-.98L2 17l1.338-3.123C2.493 12.767 2 11.434 2 10c0-3.866 3.582-7 8-7s8 3.134 8 7z"/>
            </svg>
          </div>
          <div>
            <p class="text-white font-bold text-sm leading-none">TB Assistant</p>
            <p class="text-white/60 text-xs mt-0.5">Ask me about TB</p>
          </div>
        </div>
        <button id="close-chat" class="text-white/70 hover:text-white transition-colors p-1" aria-label="Close chat">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <!-- Messages -->
      <div id="chat-messages" class="overflow-y-auto p-4 space-y-3" style="height: 300px;">
        <!-- Welcome message -->
        <div class="flex gap-2">
          <div class="w-6 h-6 rounded-full bg-primary flex-shrink-0 flex items-center justify-center mt-0.5">
            <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path d="M18 10c0 3.866-3.582 7-8 7a8.841 8.841 0 01-4.083-.98L2 17l1.338-3.123C2.493 12.767 2 11.434 2 10c0-3.866 3.582-7 8-7s8 3.134 8 7z"/>
            </svg>
          </div>
          <div class="bg-white/10 rounded-xl rounded-tl-none px-3 py-2.5 max-w-[85%]">
            <p class="text-white/90 text-xs leading-relaxed">Hi! I'm here to answer your questions about TB and the TB Free Foundation of Namibia. What would you like to know?</p>
          </div>
        </div>
        <!-- Quick question chips -->
        <div class="flex flex-wrap gap-1.5 pl-8">
          <button class="quick-q text-xs bg-white/10 hover:bg-primary/50 text-white/80 hover:text-white px-2.5 py-1 rounded-full border border-white/10 transition-colors" data-q="What is TB?">What is TB?</button>
          <button class="quick-q text-xs bg-white/10 hover:bg-primary/50 text-white/80 hover:text-white px-2.5 py-1 rounded-full border border-white/10 transition-colors" data-q="How can I donate?">How to donate?</button>
          <button class="quick-q text-xs bg-white/10 hover:bg-primary/50 text-white/80 hover:text-white px-2.5 py-1 rounded-full border border-white/10 transition-colors" data-q="How is TB treated?">TB treatment?</button>
          <button class="quick-q text-xs bg-white/10 hover:bg-primary/50 text-white/80 hover:text-white px-2.5 py-1 rounded-full border border-white/10 transition-colors" data-q="How do I volunteer?">Volunteer?</button>
        </div>
      </div>

      <!-- Input -->
      <div class="px-4 pb-4 pt-3 flex-shrink-0 border-t border-white/10">
        <div class="flex gap-2 items-center">
          <input id="chat-input" type="text" placeholder="Type your question..." autocomplete="off"
            class="flex-1 bg-white/10 text-white placeholder-white/40 text-xs rounded-lg px-3 py-2.5 outline-none focus:bg-white/15 transition-colors border border-white/10 focus:border-primary/60" />
          <button id="chat-send" class="w-9 h-9 bg-primary rounded-lg flex items-center justify-center hover:bg-primary/80 active:scale-95 transition-all flex-shrink-0" aria-label="Send">
            <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Toggle Button -->
    <button id="chat-toggle"
      class="w-14 h-14 bg-primary rounded-full shadow-2xl flex items-center justify-center hover:scale-110 active:scale-95 transition-all duration-200 border-2 border-white/20 relative"
      aria-label="Open chat assistant">
      <!-- Notification dot -->
      <span id="chat-dot" class="absolute -top-0.5 -right-0.5 w-3.5 h-3.5 bg-amber-400 rounded-full border-2 border-white animate-pulse"></span>
      <!-- Chat icon -->
      <svg id="chat-open-icon" class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
        <path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-2 12H6v-2h12v2zm0-3H6V9h12v2zm0-3H6V6h12v2z"/>
      </svg>
      <!-- Close icon -->
      <svg id="chat-close-icon" class="w-6 h-6 text-white hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <script>
    const chatToggle = document.getElementById('chat-toggle');
    const chatPanel = document.getElementById('chat-panel');
    const chatClose = document.getElementById('close-chat');
    const chatOpenIcon = document.getElementById('chat-open-icon');
    const chatCloseIcon = document.getElementById('chat-close-icon');
    const chatDot = document.getElementById('chat-dot');
    const chatMessages = document.getElementById('chat-messages')!;
    const chatInput = document.getElementById('chat-input') as HTMLInputElement;
    const chatSend = document.getElementById('chat-send');
    const quickQBtns = document.querySelectorAll<HTMLElement>('.quick-q');
    let chatOpen = false;

    const faqs: [string, string][] = [
      ["what is tb", "Tuberculosis (TB) is a serious infectious disease caused by <em>Mycobacterium tuberculosis</em>. It mainly affects the lungs but can affect other organs. TB spreads through the air when an infected person coughs or sneezes."],
      ["symptoms", "Common TB symptoms include: a persistent cough (3+ weeks), chest pain, coughing up blood, fatigue, night sweats, fever, and unexplained weight loss. Please see a healthcare professional if you experience these."],
      ["treated", "TB is treatable and curable! Treatment involves a 6-month course of antibiotics. Completing the full course is critical. Early treatment prevents spread and saves lives."],
      ["prevent", "TB can be prevented through BCG vaccination for infants, early diagnosis and treatment, good ventilation, and maintaining a strong immune system."],
      ["spread", "TB spreads through the air when an infected person coughs, sneezes, or speaks. It is not spread by sharing food, touching surfaces, or handshakes."],
      ["donate", "Thank you for your support! Visit our <a href='/donations' class='text-amber-400 underline'>Donations page</a> to make a contribution. Every donation helps TB patients in Namibia access treatment and care."],
      ["volunteer", "We'd love your help! Visit our <a href='/volunteer' class='text-amber-400 underline'>Volunteer page</a> to see available roles and how you can contribute to the fight against TB."],
      ["contact", "You can reach us via our <a href='/contact' class='text-amber-400 underline'>Contact page</a>. We'd love to hear from you!"],
      ["world tb day", "World TB Day is on <strong>24 March</strong> every year — commemorating the 1882 discovery of the TB bacterium. Learn more on our <a href='/world-tb-day' class='text-amber-400 underline'>World TB Day page</a>."],
      ["namibia", "Namibia has one of the highest TB burdens in the world. TB Free Foundation works with communities, healthcare workers, and policymakers to improve TB outcomes for all Namibians."],
      ["who are you", "We are the TB Free Foundation of Namibia — a non-profit civil society organization founded by a TB survivor. We advocate for patients' rights and work toward a TB-free Namibia. <a href='/who-we-are' class='text-amber-400 underline'>Learn more about us</a>."],
      ["about", "We are the TB Free Foundation of Namibia — a non-profit organization founded by a TB survivor dedicated to advocacy, education, and the fight against tuberculosis. <a href='/who-we-are' class='text-amber-400 underline'>Learn more about us</a>."],
      ["research", "We support and publish TB research. Visit our <a href='/research-publications' class='text-amber-400 underline'>Research Publications page</a> to explore our work."],
      ["stories", "Read inspiring TB champion stories on our <a href='/tb-champion-stories' class='text-amber-400 underline'>TB Champion Stories page</a>."],
    ];

    function getBotResponse(input: string): string {
      const lower = input.toLowerCase();
      for (const [key, val] of faqs) {
        if (lower.includes(key)) return val;
      }
      return `Thanks for your question! For detailed information, visit our <a href='/tb-questions-answers' class='text-amber-400 underline'>TB Q&A page</a> or <a href='/contact' class='text-amber-400 underline'>contact us</a> directly.`;
    }

    function addMessage(html: string, isUser: boolean) {
      const wrap = document.createElement('div');
      wrap.className = `flex gap-2${isUser ? ' justify-end' : ''}`;
      if (isUser) {
        wrap.innerHTML = `<div class="bg-primary rounded-xl rounded-tr-none px-3 py-2.5 max-w-[85%]"><p class="text-white text-xs leading-relaxed">${html}</p></div>`;
      } else {
        wrap.innerHTML = `
          <div class="w-6 h-6 rounded-full bg-primary flex-shrink-0 flex items-center justify-center mt-0.5">
            <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M18 10c0 3.866-3.582 7-8 7a8.841 8.841 0 01-4.083-.98L2 17l1.338-3.123C2.493 12.767 2 11.434 2 10c0-3.866 3.582-7 8-7s8 3.134 8 7z"/></svg>
          </div>
          <div class="bg-white/10 rounded-xl rounded-tl-none px-3 py-2.5 max-w-[85%]"><p class="text-white/90 text-xs leading-relaxed">${html}</p></div>`;
      }
      chatMessages.appendChild(wrap);
      chatMessages.scrollTop = chatMessages.scrollHeight;
    }

    function sendMessage(text: string) {
      if (!text.trim()) return;
      addMessage(text, true);
      chatInput.value = '';
      setTimeout(() => addMessage(getBotResponse(text), false), 500);
    }

    function openChat() {
      chatOpen = true;
      chatPanel?.classList.remove('hidden');
      chatOpenIcon?.classList.add('hidden');
      chatCloseIcon?.classList.remove('hidden');
      chatDot?.classList.add('hidden');
      chatInput?.focus();
    }

    function closeChat() {
      chatOpen = false;
      chatPanel?.classList.add('hidden');
      chatOpenIcon?.classList.remove('hidden');
      chatCloseIcon?.classList.add('hidden');
    }

    chatToggle?.addEventListener('click', () => chatOpen ? closeChat() : openChat());
    chatClose?.addEventListener('click', closeChat);
    chatSend?.addEventListener('click', () => sendMessage(chatInput.value));
    chatInput?.addEventListener('keydown', (e: KeyboardEvent) => { if (e.key === 'Enter') sendMessage(chatInput.value); });
    quickQBtns.forEach(btn => btn.addEventListener('click', () => sendMessage(btn.dataset.q || '')));
  </script>
</Layout>
