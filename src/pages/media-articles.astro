---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';

const articles = [
  {
    title: "TB Free Foundation Champions Patient Rights at National Health Forum",
    outlet: "The Namibian",
    date: "March 2025",
    excerpt: "Representatives from the TB Free Foundation addressed a national health forum, calling for strengthened protections for TB patients and improved access to diagnostics in rural areas.",
    type: "News",
  },
  {
    title: "World TB Day: Namibia's Silent Epidemic in the Spotlight",
    outlet: "Namibia Broadcasting Corporation",
    date: "March 2025",
    excerpt: "On World TB Day, foundation founder Karin Husselmann spoke to NBC about the ongoing struggle to eliminate tuberculosis, and what ordinary Namibians can do to help.",
    type: "Broadcast",
  },
  {
    title: "Foundation Launches Community Awareness Drive in Northern Namibia",
    outlet: "New Era Newspaper",
    date: "January 2025",
    excerpt: "The TB Free Foundation kicked off an extensive awareness campaign across the Oshana and Ohangwena regions, training community health workers and distributing educational materials.",
    type: "News",
  },
  {
    title: "Combating Stigma: How One Organisation is Changing the Conversation on TB",
    outlet: "The Villager",
    date: "November 2024",
    excerpt: "A feature on the TB Free Foundation's innovative community engagement approaches, including survivor-led dialogues and school outreach programmes across Namibia.",
    type: "Feature",
  },
  {
    title: "TB Survivor Turned Advocate Receives Civic Recognition",
    outlet: "Confidente Newspaper",
    date: "September 2024",
    excerpt: "Karin Husselmann was recognised at a civic ceremony for her decade-long commitment to TB advocacy, patient rights, and community health education in Namibia.",
    type: "News",
  },
  {
    title: "MDR-TB: Namibia's Growing Challenge and the Groups Fighting Back",
    outlet: "Southern Times",
    date: "July 2024",
    excerpt: "An in-depth report on the rising threat of drug-resistant TB in southern Africa, featuring the work of the TB Free Foundation in Namibia.",
    type: "Feature",
  },
];
---

<Layout title="Media Articles" description="Media coverage and press features about TB Free Foundation of Namibia's work, advocacy, and impact.">
  <Hero
    title="Media Articles"
    subtitle="Our work in the news — press features, broadcast highlights, and media coverage of the TB Free Foundation."
    height="medium"
  />

  <!-- Intro -->
  <section class="py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto text-center observe-animate" data-animate="animate-fade-in-up">
      <SectionHeading
        title="TB Free Foundation in the Media"
        subtitle="Amplifying the fight against TB through media partnerships and public communications — keeping Namibia informed and engaged."
        centered
      />
    </div>
  </section>

  <!-- Articles Grid -->
  <section class="pb-24 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {articles.map((article) => (
        <article class="bg-white rounded-2xl shadow-md overflow-hidden hover:shadow-xl transition-shadow duration-300 observe-animate" data-animate="animate-fade-in-up">
          <div class="h-52 bg-gradient-to-br from-primary/10 via-gray-50 to-gray-100 flex flex-col items-center justify-center gap-3 relative">
            <svg class="w-10 h-10 text-primary/30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
            </svg>
            <span class="text-xs font-semibold uppercase tracking-widest text-primary/40">Media Article</span>
            <span class="absolute top-3 left-3 bg-primary text-white text-xs font-semibold px-3 py-1 rounded-full">{article.type}</span>
          </div>
          <div class="p-6">
            <p class="text-xs text-gray-400 mb-2">{article.outlet} · {article.date}</p>
            <h3 class="text-lg font-bold text-gray-900 mb-3 leading-snug" style="font-family: var(--font-heading);">{article.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{article.excerpt}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- Media Enquiries CTA -->
  <section class="py-20 bg-[#1a1a2e]">
    <div class="max-w-3xl mx-auto text-center px-4">
      <h2 class="text-3xl font-black text-white mb-4" style="font-family: var(--font-heading);">Media Enquiries</h2>
      <p class="text-white/80 mb-8">Journalists and media professionals are welcome to reach out for interviews, statements, or expert commentary on TB in Namibia.</p>
      <a href="/contact" class="px-8 py-3.5 bg-primary text-white font-semibold rounded-lg hover:bg-primary/90 transition-colors text-sm">Contact the Foundation</a>
    </div>
  </section>
</Layout>
