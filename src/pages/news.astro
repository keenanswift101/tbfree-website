---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';

const articles = [
  {
    title: 'Concern over TB patients sharing wards in Khorixas',
    source: 'Namibian Sun',
    date: '2026',
    excerpt: 'Concern has been raised about tuberculosis patients sharing wards with general patients at a hospital in Khorixas, highlighting critical infection control failures and nosocomial transmission risks.',
    url: 'https://www.namibiansun.com/short-news/concern-over-tb-patients-sharing-wards-in-khorixas-nmh006491-1-7188',
    category: 'Health',
  },
  {
    title: "How to Help the World's Poor Most in 2026",
    source: 'The Namibian',
    date: '2026',
    excerpt: 'Experts outline the most effective ways to support vulnerable populations in 2026, including macroeconomic analysis and cost-benefit ratios of targeted TB and HIV interventions in sub-Saharan Africa.',
    url: 'https://www.namibian.com.na/how-to-help-the-worlds-poor-most-in-2026/',
    category: 'Opinion',
  },
  {
    title: 'Namibia wants to end HIV/AIDS by 2026',
    source: 'Windhoek Observer',
    date: '2026',
    excerpt: "Namibia has set an ambitious target to end HIV/AIDS by 2026, with integrated TB/HIV programs at the centre of the country's accelerated public health response.",
    url: 'https://www.observer24.com.na/namibia-wants-to-end-hiv-aids-by-2026/',
    category: 'Policy',
  },
  {
    title: 'Unregistered clinics leave inmates without medicine, report warns',
    source: 'Namibian Sun',
    date: '5 November 2025',
    excerpt: 'A new report warns that unregistered clinics within correctional facilities are leaving inmates without essential medicine, including tuberculosis treatment, due to bureaucratic and regulatory barriers.',
    url: 'https://www.namibiansun.com/police-and-crime/unregistered-clinics-leave-inmates-without-medicine-report-warns2025-11-05175872',
    category: 'Health',
  },
  {
    title: 'TB remains public health headache — as 42 deaths recorded in over two years',
    source: 'New Era',
    date: 'October 2025',
    excerpt: 'Tuberculosis persists as a public health challenge in Omusati region, with 42 deaths recorded in over two years amid concerns about missing cases and the compounding dual HIV/TB burden.',
    url: 'https://neweralive.na/tb-remains-public-health-headache-as-42-deaths-recorded-in-over-two-years/',
    category: 'Health',
  },
  {
    title: "TB health workers' promotion in limbo",
    source: 'New Era',
    date: 'October 2025',
    excerpt: 'Frontline tuberculosis health workers face stalled career promotions and unresolved labour disputes, raising urgent questions about occupational equity and the sustainability of disease surveillance.',
    url: 'https://neweralive.na/tb-health-workers-promotion-in-limbo/',
    category: 'Workforce',
  },
  {
    title: 'Namibia not close to eliminating TB — Nangombe',
    source: 'New Era',
    date: 'October 2025',
    excerpt: "Health Minister Nangombe has offered a candid assessment that Namibia remains far from eliminating tuberculosis, citing persistent undiagnosed cohorts and systemic limitations in the national response.",
    url: 'https://neweralive.na/namibia-not-close-to-eliminating-tb-nangombe/',
    category: 'Policy',
  },
  {
    title: "A mother's cry: blames negligent nurses for son's death",
    source: 'New Era',
    date: 'October 2025',
    excerpt: "A Namibian mother's account of her son's death exposes medical negligence and acute supply chain failures that left him without critical tuberculosis medication, revealing systemic gaps in respiratory care.",
    url: 'https://neweralive.na/a-mothers-cry-blames-negligent-nurses-for-sons-death/',
    category: 'Story',
  },
  {
    title: 'Namibia takes bold step to combat tuberculosis',
    source: 'New Era',
    date: 'October 2025',
    excerpt: 'Namibia has implemented new Standard Operating Procedures in the mining sector to address occupational tuberculosis and silicosis, marking a significant advance in protecting high-risk workers.',
    url: 'https://neweralive.na/namibia-takes-bold-step-to-combat-tuberculosis/',
    category: 'Occupational Health',
  },
  {
    title: 'Namibia ranked high in cases of TB worldwide',
    source: 'The Namibian',
    date: 'October 2025',
    excerpt: 'Namibia continues to rank among the countries with the highest tuberculosis burden globally, with health officials calling for sustained investment in prevention, diagnosis and treatment.',
    url: 'https://www.namibian.com.na/namibia-ranked-high-in-cases-of-tb-worldwide/',
    category: 'Health',
  },
  {
    title: 'Namibia committed to eradicating TB',
    source: 'The Namibian',
    date: 'October 2025',
    excerpt: 'The Namibian government has reaffirmed its commitment to eradicating tuberculosis, pledging to scale up community-level interventions, decentralise care, and improve rural diagnostic accessibility.',
    url: 'https://www.namibian.com.na/namibia-committed-to-eradicating-tb/',
    category: 'Policy',
  },
  {
    title: 'Zambezi records 400 tuberculosis cases in one year',
    source: 'The Namibian',
    date: 'October 2025',
    excerpt: 'The Zambezi region recorded approximately 400 tuberculosis cases in a single year, underscoring the ongoing regional epidemic and the need for intensified public health measures.',
    url: 'https://www.namibian.com.na/zambezi-records-400-tuberculosis-cases-in-one-year/',
    category: 'Regional',
  },
  {
    title: 'N$12.2 billion health budget targets e-health expansion',
    source: 'Windhoek Observer',
    date: 'October 2025',
    excerpt: "Namibia's N$12.2 billion health budget prioritises digital health expansion, marking a major shift toward domestic funding and investment in modern health infrastructure including TB-related digital services.",
    url: 'https://www.observer24.com.na/n12-2-billion-health-budget-targets-e-health-expansion/',
    category: 'Funding',
  },
  {
    title: 'Health policy to bring rules for digital health providers',
    source: 'Windhoek Observer',
    date: 'October 2025',
    excerpt: 'New health policies will introduce regulatory frameworks for digital health providers in Namibia, covering data privacy, bioethics, and the legislative architecture underpinning digital healthcare systems.',
    url: 'https://www.observer24.com.na/health-policy-to-bring-rules-for-digital-health-providers/',
    category: 'Policy',
  },
];

const badgeColor: Record<string, string> = {
  'The Namibian':       'bg-blue-100 text-blue-800',
  'Namibian Sun':       'bg-yellow-100 text-yellow-800',
  'New Era':            'bg-green-100 text-green-800',
  'Windhoek Observer':  'bg-purple-100 text-purple-800',
};
---

<Layout title="TB News" description="Latest TB-related news from Namibian publications — Namibian Sun, The Namibian, New Era and Windhoek Observer.">
  <Hero
    title="TB News"
    subtitle="Latest tuberculosis news from Namibian publications."
    height="small"
  />

  <section class="py-16 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <SectionHeading
        title="Latest Articles"
        subtitle="Hand-picked tuberculosis stories from Namibian news outlets — October 2025 onwards."
        centered
      />

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8 mt-12">
        {articles.map((article, index) => (
          <article
            class="observe-animate bg-white rounded-xl overflow-hidden shadow-sm border border-gray-100 hover:shadow-lg hover:-translate-y-1 transition-all duration-300"
            data-animate="animate-fade-in-up"
            style={`animation-delay: ${index * 0.06}s`}
          >
            <div class="p-6 flex flex-col h-full">
              <div class="flex items-center justify-between mb-3">
                <span class={`px-3 py-1 text-xs font-medium rounded-full ${badgeColor[article.source] ?? 'bg-gray-100 text-gray-700'}`}>
                  {article.source}
                </span>
                <span class="text-xs text-gray-400">{article.date}</span>
              </div>
              <span class="text-xs text-primary font-semibold uppercase tracking-wider mb-2">{article.category}</span>
              <h3 class="text-base font-bold text-gray-900 mb-3 leading-snug flex-1">{article.title}</h3>
              <p class="text-sm text-gray-600 leading-relaxed mb-5">{article.excerpt}</p>
              <a
                href={article.url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 text-sm text-primary font-medium hover:gap-3 transition-all duration-200 mt-auto"
              >
                Read full article
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- TB Facts -->
  <section class="py-20 px-4 sm:px-6 lg:px-8 bg-gray-50">
    <div class="max-w-7xl mx-auto">
      <SectionHeading title="TB Facts" subtitle="Understanding tuberculosis is the first step to ending it." centered />
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 mt-12">
        {[
          { stat: '10.6M', label: 'people fell ill with TB globally in 2022' },
          { stat: '1.3M',  label: 'TB deaths worldwide in 2022' },
          { stat: '#1',    label: 'TB is the leading infectious disease killer globally' },
          { stat: 'Curable', label: 'TB is preventable and curable with proper treatment' },
        ].map((fact) => (
          <div class="bg-white border border-primary/10 rounded-xl p-6 text-center shadow-sm">
            <p class="text-2xl font-bold text-primary mb-2">{fact.stat}</p>
            <p class="text-sm text-gray-600">{fact.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
