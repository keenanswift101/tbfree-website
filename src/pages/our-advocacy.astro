---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
---

<Layout title="Our Advocacy" description="Learn about TB Free Foundation's advocacy work in Namibia — championing care, research, and equity in health.">
  <Hero
    title="Our Advocacy"
    subtitle="Breaking barriers through evidence-based advocacy, community engagement, and a relentless commitment to ending TB in Namibia."
    height="medium"
  />

  <!-- Intro -->
  <section class="py-24 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto text-center observe-animate" data-animate="animate-fade-in-up">
      <SectionHeading
        title="What We Stand For"
        subtitle="From community clinics to the halls of government, the TB Free Foundation fights to ensure that every Namibian affected by TB is seen, heard, and supported."
        centered
      />
    </div>
  </section>

  <!-- Three Advocacy Pillars -->
  <section class="py-4 pb-24 px-4 sm:px-6 lg:px-8">
    <div class="max-w-5xl mx-auto space-y-10">

      <!-- Advocacy and Care -->
      <div class="flex gap-6 items-start observe-animate" data-animate="animate-slide-left">
        <div class="flex-shrink-0">
          <img src="/images/image1.png" alt="Advocacy and Care" class="w-20 h-20 object-contain" loading="lazy" />
        </div>
        <div class="border-l-4 border-primary pl-6 py-2">
          <h3 class="text-xl font-bold text-gray-900 mb-2" style="font-family: var(--font-heading);">Advocacy and Care</h3>
          <p class="text-gray-600 leading-relaxed">
            Every TB patient deserves high-quality care — and we fight to make that a reality. We challenge the stigma and discrimination that prevent people from seeking treatment and push for systems that put patients first.
          </p>
        </div>
      </div>

      <!-- Research and Innovation -->
      <div class="flex gap-6 items-start observe-animate" data-animate="animate-slide-left">
        <div class="flex-shrink-0">
          <img src="/images/image1.png" alt="Research and Innovation" class="w-20 h-20 object-contain" loading="lazy" />
        </div>
        <div class="border-l-4 border-primary pl-6 py-2">
          <h3 class="text-xl font-bold text-gray-900 mb-2" style="font-family: var(--font-heading);">Research and Innovation</h3>
          <p class="text-gray-600 leading-relaxed">
            Ending TB requires more than goodwill — it requires evidence, innovation, and community-led solutions. We develop and support research and strategies that make a measurable difference in TB prevention and care.
          </p>
        </div>
      </div>

      <!-- Equity in Health -->
      <div class="flex gap-6 items-start observe-animate" data-animate="animate-slide-left">
        <div class="flex-shrink-0">
          <img src="/images/image1.png" alt="Equity in Health" class="w-20 h-20 object-contain" loading="lazy" />
        </div>
        <div class="border-l-4 border-primary pl-6 py-2">
          <h3 class="text-xl font-bold text-gray-900 mb-2" style="font-family: var(--font-heading);">Equity in Health</h3>
          <p class="text-gray-600 leading-relaxed">
            TB does not affect everyone equally. We advocate fiercely for equitable access to healthcare, standing up for those who are marginalised and most at risk of slipping through the cracks of the system.
          </p>
        </div>
      </div>

    </div>
  </section>

  <!-- Together we can END TB banner -->
  <section class="py-24 px-4 sm:px-6 lg:px-8 bg-gray-50">
    <div class="max-w-5xl mx-auto">
      <div class="flex flex-col sm:flex-row items-center gap-0 rounded-2xl overflow-hidden shadow-lg observe-animate" data-animate="animate-fade-in-up">
        <div class="bg-white flex items-center justify-center p-8 w-full sm:w-56 flex-shrink-0 border-r border-gray-100">
          <img src="/images/image34.1.png" alt="Together we can end TB" class="w-32 h-32 object-contain" loading="lazy" />
        </div>
        <div class="bg-white px-12 py-10 flex-1 border-t sm:border-t-0 sm:border-l border-gray-100">
          <div class="w-16 h-1 bg-gray-200 mb-6"></div>
          <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 leading-tight mb-4" style="font-family: var(--font-heading);">
            Together we can <span class="text-primary">END</span> the <span class="text-primary">TB</span> pandemic
          </h2>
          <div class="w-16 h-1 bg-gray-200 mt-6"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Advocacy Areas Grid -->
  <section class="py-24 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16 observe-animate" data-animate="animate-fade-in-up">
        <SectionHeading
          title="Our Advocacy Work"
          subtitle="From grassroots community engagement to national policy influence."
          centered
        />
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="rounded-2xl overflow-hidden shadow-sm border border-gray-100 hover:shadow-lg transition-all duration-300 observe-animate" data-animate="animate-fade-in-up">
          <div class="w-full h-48 bg-gray-200 flex items-center justify-center">
            <div class="text-center text-gray-400">
              <svg class="w-10 h-10 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
              <span class="text-xs font-medium">Photo coming soon</span>
            </div>
          </div>
          <div class="p-6">
            <h3 class="font-bold text-gray-900 mb-2">Community Advocacy</h3>
            <p class="text-sm text-gray-600 leading-relaxed">Knowledge is power. We mobilise communities to understand their rights and access the TB services they deserve — free from fear, stigma, and discrimination.</p>
          </div>
        </div>
        <div class="rounded-2xl overflow-hidden shadow-sm border border-gray-100 hover:shadow-lg transition-all duration-300 observe-animate delay-100" data-animate="animate-fade-in-up">
          <div class="w-full h-48 bg-gray-200 flex items-center justify-center">
            <div class="text-center text-gray-400">
              <svg class="w-10 h-10 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
              <span class="text-xs font-medium">Photo coming soon</span>
            </div>
          </div>
          <div class="p-6">
            <h3 class="font-bold text-gray-900 mb-2">Policy Engagement</h3>
            <p class="text-sm text-gray-600 leading-relaxed">Real change happens at every level. We engage government, the Ministry of Health and Social Services, and international partners to ensure that TB policy reflects the realities and rights of those most affected.</p>
          </div>
        </div>
        <div class="rounded-2xl overflow-hidden shadow-sm border border-gray-100 hover:shadow-lg transition-all duration-300 observe-animate delay-200" data-animate="animate-fade-in-up">
          <div class="w-full h-48 bg-gray-200 flex items-center justify-center">
            <div class="text-center text-gray-400">
              <svg class="w-10 h-10 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
              <span class="text-xs font-medium">Photo coming soon</span>
            </div>
          </div>
          <div class="p-6">
            <h3 class="font-bold text-gray-900 mb-2">Stigma Reduction</h3>
            <p class="text-sm text-gray-600 leading-relaxed">Stigma costs lives. We run awareness campaigns that confront misconceptions about TB head-on, building a society where those affected are treated with the compassion and dignity they deserve.</p>
          </div>
        </div>
        <div class="rounded-2xl overflow-hidden shadow-sm border border-gray-100 hover:shadow-lg transition-all duration-300 observe-animate" data-animate="animate-fade-in-up">
          <div class="w-full h-48 bg-gray-200 flex items-center justify-center">
            <div class="text-center text-gray-400">
              <svg class="w-10 h-10 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
              <span class="text-xs font-medium">Photo coming soon</span>
            </div>
          </div>
          <div class="p-6">
            <h3 class="font-bold text-gray-900 mb-2">World TB Day</h3>
            <p class="text-sm text-gray-600 leading-relaxed">Every year on World TB Day, we raise our voices louder. Through community events, media engagement, and national calls to action, we remind Namibia — and the world — that ending TB is possible.</p>
          </div>
        </div>
        <div class="rounded-2xl overflow-hidden shadow-sm border border-gray-100 hover:shadow-lg transition-all duration-300 observe-animate delay-100" data-animate="animate-fade-in-up">
          <div class="w-full h-48 bg-gray-200 flex items-center justify-center">
            <div class="text-center text-gray-400">
              <svg class="w-10 h-10 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
              <span class="text-xs font-medium">Photo coming soon</span>
            </div>
          </div>
          <div class="p-6">
            <h3 class="font-bold text-gray-900 mb-2">Patient Support</h3>
            <p class="text-sm text-gray-600 leading-relaxed">A diagnosis is just the beginning. We stand with TB patients throughout their journey — providing access to peer support, nutritional assistance, and psychosocial counselling when they need it most.</p>
          </div>
        </div>
        <div class="rounded-2xl overflow-hidden shadow-sm border border-gray-100 hover:shadow-lg transition-all duration-300 observe-animate delay-200" data-animate="animate-fade-in-up">
          <div class="w-full h-48 bg-gray-200 flex items-center justify-center">
            <div class="text-center text-gray-400">
              <svg class="w-10 h-10 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
              <span class="text-xs font-medium">Photo coming soon</span>
            </div>
          </div>
          <div class="p-6">
            <h3 class="font-bold text-gray-900 mb-2">Research Support</h3>
            <p class="text-sm text-gray-600 leading-relaxed">Ending TB demands innovation. We support local and international research that pushes the boundaries of TB diagnostics, treatment, and prevention — bringing a TB-free future closer every day.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 px-4 sm:px-6 lg:px-8 bg-[#1a1a2e]">
    <div class="max-w-4xl mx-auto text-center observe-animate" data-animate="animate-fade-in-up">
      <p class="text-[#f4a261] font-semibold text-sm uppercase tracking-wider mb-4">Join the Movement</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-6" style="font-family: var(--font-heading);">
        Support Our Advocacy Efforts
      </h2>
      <p class="text-white/75 text-lg leading-relaxed mb-10 max-w-2xl mx-auto">
        Every voice matters in the fight to end TB. Whether you donate, volunteer, or simply share our message — you are part of the solution.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/donations" class="inline-flex items-center gap-2 bg-primary text-white px-8 py-4 rounded-full font-semibold hover:bg-primary/90 transition-colors duration-200">
          Donate Now
        </a>
        <a href="/contact" class="inline-flex items-center gap-2 bg-white/10 text-white border border-white/30 px-8 py-4 rounded-full font-semibold hover:bg-white/20 transition-colors duration-200">
          Get Involved
        </a>
      </div>
    </div>
  </section>
</Layout>
